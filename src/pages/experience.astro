---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Experience" language="TypeScript" currentFile="work/experience.ts">
  <div class="max-w-3xl">
    <div class="flex items-center justify-between border-b border-[#2b2b2b] pb-2 mb-6">
      <h1 class="text-2xl font-bold text-white">experience.ts</h1>
    </div>
    
    <div class="bg-[#1e1e1e] p-6 rounded-md border border-[#2b2b2b] text-sm overflow-x-auto">
<pre><code><span class="text-pink-400">interface</span> <span class="text-yellow-400">Role</span> {'{'}
  company: <span class="text-blue-400">string</span>;
  title: <span class="text-blue-400">string</span>;
  period: <span class="text-blue-400">string</span>;
  highlights: <span class="text-blue-400">string</span>[];
{'}'}

<span class="text-pink-400">export const</span> <span class="text-blue-400">experience</span>: <span class="text-yellow-400">Role</span>[] <span class="text-pink-400">=</span> [
  <span class="text-green-400 border-l-2 border-green-400 pl-2 block my-2">// Current Role</span>
  {'{'}
    company: <span class="text-yellow-300">'Tech Innovators Inc.'</span>,
    title: <span class="text-yellow-300">'Senior Software Engineer'</span>,
    period: <span class="text-yellow-300">'2023 - Present'</span>,
    highlights: [
      <span class="text-yellow-300">'Led the migration from monolithic architecture to microservices using Node.js and Docker.'</span>,
      <span class="text-yellow-300">'Reduced API response time by 40% through Redis caching implementation.'</span>,
      <span class="text-yellow-300">'Mentored 3 junior developers and established team code review guidelines.'</span>
    ]
  {'}'},
  
  <span class="text-[#858585] border-l-2 border-[#858585] pl-2 block my-2">// Previous Role</span>
  {'{'}
    company: <span class="text-yellow-300">'Startup Alpha'</span>,
    title: <span class="text-yellow-300">'Full Stack Developer'</span>,
    period: <span class="text-yellow-300">'2020 - 2023'</span>,
    highlights: [
      <span class="text-yellow-300">'Built the core SaaS platform from scratch using React and Python (FastAPI).'</span>,
      <span class="text-yellow-300">'Implemented Stripe billing integration for 3 subscription tiers.'</span>,
      <span class="text-yellow-300">'Managed AWS infrastructure using Terraform.'</span>
    ]
  {'}'}
];
</code></pre>
    </div>
  </div>
</Layout>