---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/landing/Navbar.astro';
import Hero from '../components/landing/Hero.astro';
import Specs from '../components/landing/Specs.astro';
import Benchmarks from '../components/landing/Benchmarks.astro';
import Reliability from '../components/landing/Reliability.astro';
import Sponsor from '../components/landing/Sponsor.astro';
import Deployment from '../components/landing/Deployment.astro';
import Pricing from '../components/landing/Pricing.astro';

interface Props {
  title: string;
}
---

<Layout title="Meet LuizFCM 3.6">
  <Navbar />
  <main class="relative">
    <div class="relative"><Hero /></div>
    
    <div class="relative border-y border-white/5 py-8">
      <div class="hud-corner-tl !left-4 !top-4"></div>
      <div class="hud-corner-tr !right-4 !top-4"></div>
      <Specs />
    </div>

    <div class="relative border-y border-white/5 py-8">
      <Benchmarks />
    </div>

    <div class="relative border-y border-white/5 py-8">
      <div class="hud-corner-bl !left-4 !bottom-4"></div>
      <div class="hud-corner-br !right-4 !bottom-4"></div>
      <Reliability />
    </div>

    <div class="relative border-y border-white/5 py-8">
      <Sponsor />
    </div>

    <div class="relative border-y border-white/5 py-8">
       <div class="absolute top-4 left-4 text-[8px] font-fira text-white/20 uppercase tracking-widest">
          Version_Log_Buffer // Read_Only
       </div>
      <Deployment />
    </div>

    <div class="relative border-y border-white/5 py-8 bg-[#050505]/50">
      <Pricing />
    </div>
  </main>
  
  <footer class="py-12 border-t border-[#330033] bg-[#050505] px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex items-center gap-2">
        <span class="font-bold text-xl tracking-tighter text-[#ff00ff]">LUIZFCM<span class="text-[#00ffff]">-3.6</span></span>
        <span class="text-[10px] text-[#555] font-fira ml-4">© 2026 HUMAN_UNIT_PROD_RESERVED</span>
      </div>
      
      <div class="flex gap-8 text-[10px] font-fira uppercase tracking-[0.2em] text-[#858585]">
        <a href="https://github.com/luiz1361" class="hover:text-[#ff00ff]" target="_blank">GitHub</a>
        <a href="https://www.linkedin.com/in/luiz1361/" class="hover:text-[#00ffff]" target="_blank">LinkedIn</a>
      </div>
    </div>
  </footer>
</Layout>