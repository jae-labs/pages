---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" language="JSON" currentFile="personal/contact.json">
  <div class="max-w-3xl">
    <div class="flex items-center justify-between border-b border-[#2b2b2b] pb-2 mb-6">
      <h1 class="text-2xl font-bold text-white">contact.json</h1>
    </div>
    
    <div class="bg-[#1e1e1e] p-6 rounded-md border border-[#2b2b2b] text-sm overflow-x-auto">
<pre><code>{'{'}
  <span class="text-blue-300">"status"</span>: <span class="text-green-400">"accepting_opportunities"</span>,
  <span class="text-blue-300">"contact_methods"</span>: {'{'}
    <span class="text-blue-300">"email"</span>: <span class="text-yellow-300">"hello@yourdomain.com"</span>,
    <span class="text-blue-300">"linkedin"</span>: <span class="text-yellow-300">"https://linkedin.com/in/yourprofile"</span>,
    <span class="text-blue-300">"github"</span>: <span class="text-yellow-300">"https://github.com/yourusername"</span>
  {'}'},
  <span class="text-blue-300">"preferred_communication"</span>: <span class="text-yellow-300">"email"</span>,
  <span class="text-blue-300">"timezone"</span>: <span class="text-yellow-300">"UTC+1"</span>,
  <span class="text-blue-300">"message"</span>: <span class="text-yellow-300">"Feel free to reach out for collaborations, freelance work, or just to say hi!"</span>
{'}'}
</code></pre>
    </div>
  </div>
</Layout>