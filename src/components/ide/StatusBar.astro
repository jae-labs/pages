---
import { GitBranch, CheckCheck, Bell } from 'lucide-astro';

const { language = 'Markdown' } = Astro.props;
---

<div class="h-6 bg-[#007acc] text-white text-xs flex items-center justify-between px-3 flex-shrink-0">
  <div class="flex items-center gap-4 h-full">
    <div class="flex items-center gap-1 cursor-pointer hover:bg-white/20 h-full px-2">
      <GitBranch size={12} />
      <span>main*</span>
    </div>
    <div class="flex items-center gap-1 cursor-pointer hover:bg-white/20 h-full px-2">
      <span class="w-2 h-2 rounded-full bg-green-400"></span>
      <span>System Normal</span>
    </div>
  </div>

  <div class="flex items-center gap-4 h-full">
    <div class="flex items-center cursor-pointer hover:bg-white/20 h-full px-2">
      UTF-8
    </div>
    <div class="flex items-center cursor-pointer hover:bg-white/20 h-full px-2">
      {language}
    </div>
    <div class="flex items-center gap-1 cursor-pointer hover:bg-white/20 h-full px-2">
      <CheckCheck size={14} />
      Prettier
    </div>
    <div class="flex items-center cursor-pointer hover:bg-white/20 h-full px-2">
      <Bell size={14} />
    </div>
  </div>
</div>