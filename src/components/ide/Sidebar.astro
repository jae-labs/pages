---
import { ChevronDown, ChevronRight, FileJson, FileType2, Terminal } from 'lucide-astro';

const currentPath = Astro.url.pathname;

const files = [
  { name: 'README.md', path: '/', icon: Terminal, color: 'text-green-400' },
  {
    name: 'personal',
    type: 'folder',
    isOpen: true,
    children: [
      { name: 'about.me', path: '/about', icon: FileType2, color: 'text-blue-400' },
      { name: 'contact.json', path: '/contact', icon: FileJson, color: 'text-yellow-400' },
    ]
  },
  {
    name: 'work',
    type: 'folder',
    isOpen: true,
    children: [
      { name: 'experience.ts', path: '/experience', icon: FileType2, color: 'text-blue-500' },
    ]
  }
];
---

<div class="w-60 h-full bg-[#1e1e1e] border-r border-[#2b2b2b] flex-shrink-0 flex flex-col text-[#cccccc] text-sm">
  <div class="px-4 py-3 text-xs font-semibold tracking-wider text-[#858585] uppercase">
    Explorer
  </div>
  
  <div class="flex-1 overflow-y-auto overflow-x-hidden">
    <div class="px-2">
      <div class="flex items-center py-1 cursor-pointer font-bold">
        <ChevronDown size={16} class="mr-1" />
        PORTFOLIO
      </div>
      
      <div class="pl-4 flex flex-col gap-[2px]">
        {/* README */}
        <a href="/" class={`flex items-center py-1 px-2 hover:bg-[#2a2d2e] rounded cursor-pointer ${currentPath === '/' ? 'bg-[#37373d] text-white' : ''}`}>
           <Terminal size={14} class="mr-2 text-green-400" />
           README.md
        </a>

        {/* Personal Folder */}
        <div class="flex items-center py-1 px-2 hover:bg-[#2a2d2e] rounded cursor-pointer">
          <ChevronDown size={14} class="mr-1 text-[#858585]" />
          personal
        </div>
        <div class="pl-5 flex flex-col gap-[2px]">
           <a href="/about" class={`flex items-center py-1 px-2 hover:bg-[#2a2d2e] rounded cursor-pointer ${currentPath === '/about' ? 'bg-[#37373d] text-white' : ''}`}>
             <FileType2 size={14} class="mr-2 text-blue-400" />
             about.me
           </a>
           <a href="/contact" class={`flex items-center py-1 px-2 hover:bg-[#2a2d2e] rounded cursor-pointer ${currentPath === '/contact' ? 'bg-[#37373d] text-white' : ''}`}>
             <FileJson size={14} class="mr-2 text-yellow-400" />
             contact.json
           </a>
        </div>

        {/* Work Folder */}
        <div class="flex items-center py-1 px-2 hover:bg-[#2a2d2e] rounded cursor-pointer mt-1">
          <ChevronDown size={14} class="mr-1 text-[#858585]" />
          work
        </div>
        <div class="pl-5 flex flex-col gap-[2px]">
           <a href="/experience" class={`flex items-center py-1 px-2 hover:bg-[#2a2d2e] rounded cursor-pointer ${currentPath === '/experience' ? 'bg-[#37373d] text-white' : ''}`}>
             <FileType2 size={14} class="mr-2 text-blue-500" />
             experience.ts
           </a>
        </div>
      </div>
    </div>
  </div>
</div>