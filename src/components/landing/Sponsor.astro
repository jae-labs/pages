---
import { Image } from 'astro:assets';
import { ChevronLeft, ChevronRight } from '@lucide/astro';
import laptopSwagImg from '../../assets/laptop-swag.png';
import tacticalGearImg from '../../assets/tactical-gear.jpeg';
import geminiSponsorImg from '../../assets/gemini-generated-29c3bb.png';
---

<section id="sponsor" class="py-12 px-6 relative bg-black overflow-hidden border-y border-white/5">
  <div class="max-w-4xl xl:max-w-6xl 2xl:max-w-7xl mx-auto relative z-10">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h2 class="text-4xl md:text-7xl xl:text-7xl 2xl:text-8xl font-black text-white italic uppercase tracking-tighter glitch" data-text="SPONSOR">SPONSOR</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
      <div>
        <div class="space-y-6 text-[#aaa] text-sm xl:text-base 2xl:text-lg leading-relaxed">
          <p class="text-lg">
            lui.z 3.7 Pro supports high-visibility brand integration during <span class="text-white font-bold">temporary deployments across over 50 countries</span>. 
          </p>
          <p>
            Secure premium placement on primary hardware and tactical gear used at global conferences, technical workshops, and high-traffic nodes.
          </p>
        </div>
      </div>

      <div class="relative">
        <div class="overflow-hidden rounded-2xl border border-white/10 shadow-2xl">
          <div class="flex transition-transform duration-500 ease-in-out" style="transform: translateX(-0%)" data-carousel-track>
            <div class="min-w-0 w-full shrink-0">
              <Image src={laptopSwagImg} alt="MacBook Sponsorship Space" width={800} class="w-full h-auto" />
            </div>
            <div class="min-w-0 w-full shrink-0">
              <Image src={tacticalGearImg} alt="Tactical Gear Sponsorship Space" width={800} class="w-full h-auto" />
            </div>
            <div class="min-w-0 w-full shrink-0">
              <Image src={geminiSponsorImg} alt="Sponsorship Space" width={800} class="w-full h-auto" />
            </div>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3 mt-4">
          <button type="button" data-carousel-prev aria-label="Previous slide" class="flex items-center justify-center w-8 h-8 rounded-full border border-white/20 text-white/60 hover:text-white hover:border-white/50 transition-colors cursor-pointer">
            <ChevronLeft size={18} />
          </button>
          <div class="flex gap-2 items-center" data-carousel-dots>
            <button type="button" data-carousel-dot="0" aria-label="Go to slide 1" class="w-6 h-6 flex items-center justify-center transition-colors cursor-pointer">
              <span class="w-2 h-2 rounded-full bg-white/60 transition-colors pointer-events-none"></span>
            </button>
            <button type="button" data-carousel-dot="1" aria-label="Go to slide 2" class="w-6 h-6 flex items-center justify-center transition-colors cursor-pointer">
              <span class="w-2 h-2 rounded-full bg-white/20 transition-colors pointer-events-none"></span>
            </button>
            <button type="button" data-carousel-dot="2" aria-label="Go to slide 3" class="w-6 h-6 flex items-center justify-center transition-colors cursor-pointer">
              <span class="w-2 h-2 rounded-full bg-white/20 transition-colors pointer-events-none"></span>
            </button>
          </div>
          <button type="button" data-carousel-next aria-label="Next slide" class="flex items-center justify-center w-8 h-8 rounded-full border border-white/20 text-white/60 hover:text-white hover:border-white/50 transition-colors cursor-pointer">
            <ChevronRight size={18} />
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector('[data-carousel-track]') as HTMLElement | null;
  if (track) {
    const slides = track.children.length;
    let current = 0;
    let interval: ReturnType<typeof setInterval> | null = null;

    function update(i: number) {
      current = (i + slides) % slides;
      track!.style.transform = `translateX(-${current * 100}%)`;
      document.querySelectorAll('[data-carousel-dot]').forEach((dot, j) => {
        const active = j === current;
        const inner = dot.querySelector('span');
        if (inner) {
          inner.className = `w-2 h-2 rounded-full transition-colors ${active ? 'bg-white/60' : 'bg-white/20'}`;
        }
      });
    }

    function startAutoplay() {
      stopAutoplay();
      interval = setInterval(() => update(current + 1), 5000);
    }

    function stopAutoplay() {
      if (interval) {
        clearInterval(interval);
        interval = null;
      }
    }

    function restartAutoplay() {
      startAutoplay();
    }

    document.querySelector('[data-carousel-prev]')?.addEventListener('click', () => { update(current - 1); restartAutoplay(); });
    document.querySelector('[data-carousel-next]')?.addEventListener('click', () => { update(current + 1); restartAutoplay(); });
    document.querySelectorAll<HTMLElement>('[data-carousel-dot]').forEach((dot) => {
      dot.addEventListener('click', () => { update(Number(dot.dataset.carouselDot)); restartAutoplay(); });
    });

    const container = track.closest('.relative');
    container?.addEventListener('mouseenter', stopAutoplay);
    container?.addEventListener('mouseleave', startAutoplay);

    startAutoplay();

    document.addEventListener('astro:before-preparation', stopAutoplay);
  }
</script>
