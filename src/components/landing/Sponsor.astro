---
import { Megaphone } from '@lucide/astro';
---

<section id="sponsor" class="py-24 px-6 relative bg-black overflow-hidden border-t border-[#330033]/30">
  <div class="max-w-4xl mx-auto relative z-10">
    <div class="mb-16">
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter">SPONSOR</h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
      <div>
        <div class="space-y-6 text-[#858585] leading-relaxed">
          <p class="text-lg">
            LuizFCM 3.6 supports high-visibility brand integration during <span class="text-white font-bold">temporary deployments across over 50 countries</span>. 
          </p>
          <p>
            Secure premium placement on primary hardware and tactical gear used at global conferences, technical workshops, and high-traffic nodes.
          </p>
        </div>
      </div>

      <div class="relative group">
        <div class="absolute -inset-2 bg-gradient-to-r from-[#ff00ff]/20 to-[#00ffff]/20 rounded-3xl blur-xl opacity-50 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative bg-black border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
           <img src="/laptop-swag.png" alt="MacBook Sponsorship Space" class="w-full h-auto" />
           <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-6">
              <span class="text-[10px] font-fira text-white/50 uppercase tracking-widest">Primary Hardware Real Estate</span>
           </div>
        </div>
      </div>
    </div>

    <div class="bg-[#ff00ff]/5 border border-[#ff00ff]/20 rounded-3xl p-8 text-center relative group">
       <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-neon-pink text-black text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full shadow-[0_0_20px_#ff00ff]">
          Partner Opportunity
       </div>
       <h4 class="text-2xl font-black text-white mb-4 italic uppercase">Book Your Ad Space</h4>
       <p class="text-sm text-[#858585] mb-8 max-w-xl mx-auto">
          From hardware stickers to tactical apparel. Secure your placement for the next global deployment cycle.
       </p>
       <a href="mailto:hello@luizfcm.com" class="inline-flex items-center gap-2 px-8 py-3 bg-neon-pink text-black font-black uppercase tracking-widest rounded-lg hover:shadow-[0_0_30px_#ff00ff] transition-all">
          <Megaphone size={18} /> Contact Sales
       </a>
    </div>
  </div>
</section>