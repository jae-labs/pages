---
import { Megaphone, Globe, Laptop, Shirt, Backpack, Coffee } from '@lucide/astro';

const swagItems = [
  {
    title: "MacBook Surface",
    desc: "Primary real estate for high-visibility laptop stickers at global dev conferences.",
    icon: Laptop,
    placeholder: "STICKER_HERE",
    color: "from-gray-800 to-gray-900"
  },
  {
    title: "Chassis Branded Gear",
    desc: "T-shirts and hoodies worn during keynotes and technical workshops.",
    icon: Shirt,
    placeholder: "LOGO_HERE",
    color: "from-[#111] to-[#222]"
  },
  {
    title: "Mobile Storage Unit",
    desc: "Backpack branding for maximum exposure during international transit.",
    icon: Backpack,
    placeholder: "YOUR_BRAND",
    color: "from-zinc-900 to-black"
  },
  {
    title: "Hydration Module",
    desc: "Squeeze bottles and mugs featured in all 'Caffeinated Mode' sessions.",
    icon: Coffee,
    placeholder: "CO_LOGO",
    color: "from-slate-900 to-zinc-900"
  }
];
---

<section id="sponsor" class="py-24 px-6 relative bg-black overflow-hidden border-t border-[#330033]/30">
  <div class="max-w-4xl mx-auto relative z-10">
    <div class="mb-16">
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter">SPONSOR</h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
      <div>
        <h2 class="text-[#00ffff] font-fira text-sm mb-4 tracking-[0.3em] uppercase">Biological Advertisement</h2>
        <p class="text-lg text-white mb-6 font-bold uppercase tracking-tight italic">Global Exposure. Zero Latency Branding.</p>
        <div class="space-y-6 text-[#858585] leading-relaxed">
          <p>
            LuizFCM 3.6 is a mobile high-performance unit with a global footprint. Having been deployed to <span class="text-white font-bold">over 50 countries</span>, this biological agent provides premium placement for your organization's visual identity.
          </p>
          <div class="flex items-center gap-4 py-4 px-6 bg-white/5 border border-white/10 rounded-2xl shadow-inner">
             <div class="shrink-0 w-12 h-12 rounded-full bg-[#00ffff]/10 flex items-center justify-center text-[#00ffff]">
                <Globe size={24} />
             </div>
             <div>
                <span class="block text-white font-bold text-sm uppercase">Global Transit Enabled</span>
                <span class="text-[10px] uppercase font-fira tracking-widest">50+ Regions Reached</span>
             </div>
          </div>
          <p class="text-sm italic">
            "Your logo on my hardware. Your mission in my bio-processing loop."
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {swagItems.map((item) => (
          <div class={`aspect-square rounded-2xl bg-gradient-to-br ${item.color} border border-white/10 p-6 flex flex-col items-center justify-center group hover:border-[#ff00ff]/50 transition-all relative overflow-hidden shadow-2xl`}>
             {/* Swag Placeholder UI */}
             <div class="absolute inset-0 flex items-center justify-center opacity-20 group-hover:opacity-40 transition-opacity">
                <item.icon size={120} strokeWidth={0.5} />
             </div>
             
             {/* The "Logo" Placeholder */}
             <div class="relative z-10 w-full aspect-video border-2 border-dashed border-[#ff00ff]/40 rounded flex items-center justify-center bg-black/40 backdrop-blur-sm group-hover:border-[#ff00ff] transition-all">
                <span class="text-[10px] font-black font-fira text-[#ff00ff] tracking-tighter uppercase">{item.placeholder}</span>
             </div>
             
             <span class="relative z-10 mt-4 text-[10px] font-black text-white uppercase tracking-widest text-center">{item.title}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-[#ff00ff]/5 border border-[#ff00ff]/20 rounded-3xl p-8 text-center relative group">
       <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-neon-pink text-black text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full shadow-[0_0_20px_#ff00ff]">
          Partner Opportunity
       </div>
       <h4 class="text-2xl font-black text-white mb-4 italic uppercase">Book Your Ad Space</h4>
       <p class="text-sm text-[#858585] mb-8 max-w-xl mx-auto">
          From conference stickers to custom mugs used in high-stakes war rooms. Secure your placement for the next global deployment cycle.
       </p>
       <a href="mailto:hello@luizfcm.com" class="inline-flex items-center gap-2 px-8 py-3 bg-neon-pink text-black font-black uppercase tracking-widest rounded-lg hover:shadow-[0_0_30px_#ff00ff] transition-all">
          <Megaphone size={18} /> Contact Sales
       </a>
    </div>
  </div>
</section>