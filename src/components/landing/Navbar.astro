---
import { Coffee } from '@lucide/astro';
import CyborgBrainLogo from '../branding/CyborgBrainLogo.astro';
import GitHubIcon from '../icons/GitHubIcon.astro';
import LinkedInIcon from '../icons/LinkedInIcon.astro';
import SlackIcon from '../icons/SlackIcon.astro';
import { menuItems } from '../../config/portfolio';

const mobileItems = menuItems;
---

<nav id="main-nav" aria-label="Main Navigation" class="fixed top-0 w-full z-[300] bg-black/80 backdrop-blur-xl border-b border-[#f3eb2c]/20 px-6 py-3 transition-colors duration-300">
  <div class="max-w-7xl mx-auto relative z-[600] flex items-center justify-center min-h-10">
    <a href="/" class="absolute left-0 flex items-center gap-3 group cursor-pointer" aria-label="lui.z Homepage">
      <CyborgBrainLogo class="h-10 w-10 shrink-0 transition-transform duration-300 group-hover:scale-105" />
      <div class="flex flex-col">
        <span class="font-black text-xl tracking-tighter text-white leading-none glitch" data-text="lui.z">lui.z</span>
      </div>
    </a>
    
    <div class="hidden md:flex items-center gap-3 lg:gap-5">
      {/* Desktop Links - Horizontal List with Separators */}
      <div class="flex items-center gap-2 lg:gap-3 text-[11px] font-black uppercase tracking-[0.12em] text-[#858585]">
         {menuItems.map((item, index) => (
            <div class="flex items-center gap-2 lg:gap-3">
               <a href={`#${item.id}`} class="hover:text-white transition-all py-1 border-b border-transparent hover:border-neon-yellow whitespace-nowrap">
                 {item.name}
                </a>
              {index < menuItems.length - 1 && <span class="text-[#444] opacity-50" aria-hidden="true">|</span>}
            </div>
         ))}
      </div>
    </div>

    <div class="absolute right-0 hidden lg:flex items-center gap-4 text-[#858585]">
      <a href="https://github.com/luiz1361" target="_blank" rel="noopener noreferrer" class="hover:text-neon-yellow transition-colors" aria-label="GitHub profile">
        <GitHubIcon size={18} />
      </a>
      <a href="https://join.slack.com/t/justanotherengineer/shared_invite/zt-23m74nwgy-STbP1b2nskLTz5Ql3NRtTQ" target="_blank" rel="noopener noreferrer" class="hover:text-neon-yellow transition-colors" aria-label="Slack channel">
        <SlackIcon size={18} />
      </a>
      <a href="https://linkedin.com/in/luiz1361" target="_blank" rel="noopener noreferrer" class="hover:text-neon-cyan transition-colors" aria-label="LinkedIn profile">
        <LinkedInIcon size={18} />
      </a>
      <a href="https://buymeacoffee.com/luiz1361" target="_blank" rel="noopener noreferrer" class="hover:text-neon-yellow transition-colors" aria-label="Buy me a coffee">
        <Coffee size={18} strokeWidth={1.5} />
      </a>
    </div>

    {/* Sandwich Menu Toggle - Mobile Only */}
    <button
      id="menu-toggle"
      class="md:hidden absolute right-0 w-10 h-10 flex items-center justify-center text-white hover:text-neon-yellow transition-colors group z-[700]"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
       <div class="space-y-1.5 pointer-events-none">
          <div class="w-6 h-0.5 bg-current transition-all group-[.open]:rotate-45 group-[.open]:translate-y-2"></div>
          <div class="w-6 h-0.5 bg-current transition-all group-[.open]:opacity-0"></div>
          <div class="w-6 h-0.5 bg-current transition-all group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></div>
       </div>
    </button>
  </div>
</nav>

{/* Fullscreen Mobile Menu - Optimized Centering & Spacing */}
<div
  id="nav-menu"
  role="dialog"
  aria-label="Mobile Navigation"
  class="md:hidden fixed inset-0 bg-black z-[400] translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] overflow-y-auto"
>
  <div class="absolute inset-0 cyber-grid opacity-20 pointer-events-none"></div>
  
  <div class="flex flex-col items-center justify-center min-h-screen py-16 px-6">
    <nav class="flex flex-col items-center w-full relative z-10">
      {mobileItems.map((item) => (
        <a href={`#${item.id}`} class="nav-link w-full py-3.5 border-b border-white/5 flex flex-col items-center group hover:bg-white/[0.02] transition-all first:border-t">
           <span class="text-xl font-black uppercase tracking-[0.2em] text-[#858585] group-hover:text-white transition-colors">{item.name}</span>
        </a>
      ))}
    </nav>

    <div class="mt-8 pt-8 border-t border-white/5 w-full max-w-xs text-center flex flex-col items-center z-10 shrink-0">
       <div class="flex gap-10 text-[#444]">
          <a href="https://github.com/luiz1361" target="_blank" rel="noopener noreferrer" class="hover:text-neon-yellow transition-colors" aria-label="GitHub profile">
            <GitHubIcon size={24} />
          </a>
          <a href="https://join.slack.com/t/justanotherengineer/shared_invite/zt-23m74nwgy-STbP1b2nskLTz5Ql3NRtTQ" target="_blank" rel="noopener noreferrer" class="hover:text-neon-yellow transition-colors" aria-label="Slack channel">
            <SlackIcon size={24} />
          </a>
          <a href="https://linkedin.com/in/luiz1361" target="_blank" rel="noopener noreferrer" class="hover:text-neon-cyan transition-colors" aria-label="LinkedIn profile">
            <LinkedInIcon size={24} />
          </a>
          <a href="https://buymeacoffee.com/luiz1361" target="_blank" rel="noopener noreferrer" class="hover:text-neon-yellow transition-colors" aria-label="Buy me a coffee">
            <Coffee size={24} strokeWidth={1.5} />
          </a>
       </div>
    </div>
  </div>
</div>

<script>
  const initNavbar = () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('nav-menu');
    const nav = document.getElementById('main-nav');
    const links = document.querySelectorAll('.nav-link');

    if (!toggle || !menu || !nav) return;

    // Prevent duplicate event listener registration on Astro page-load / DomContentLoaded
    if (toggle.dataset.bound === 'true') return;
    toggle.dataset.bound = 'true';

    const toggleMenu = () => {
      const isOpen = toggle.classList.toggle('open');
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      menu.classList.toggle('translate-x-full');
      document.body.classList.toggle('overflow-hidden');
      
      if (isOpen) {
        nav.classList.remove('bg-black/80');
        nav.classList.add('bg-black');
      } else {
        nav.classList.remove('bg-black');
        nav.classList.add('bg-black/80');
      }
    };

    const closeMenu = () => {
      toggle.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      menu.classList.add('translate-x-full');
      document.body.classList.remove('overflow-hidden');
      nav.classList.remove('bg-black');
      nav.classList.add('bg-black/80');
    };

    toggle.addEventListener('click', toggleMenu);

    links.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        closeMenu();
      }
    };

    window.addEventListener('keydown', handleEscape);

    // Save escape handler reference globally to clean it up before ClientRouter swaps the DOM
    (window as any).__cleanupNavbarEscape = () => {
      window.removeEventListener('keydown', handleEscape);
    };
  };

  if (document.readyState !== 'loading') {
    initNavbar();
  } else {
    document.addEventListener('DOMContentLoaded', initNavbar, { once: true });
  }

  document.addEventListener('astro:page-load', initNavbar);

  // Clean up global listeners to prevent leaks
  document.addEventListener('astro:before-preparation', () => {
    if (typeof (window as any).__cleanupNavbarEscape === 'function') {
      (window as any).__cleanupNavbarEscape();
    }
  });
</script>

