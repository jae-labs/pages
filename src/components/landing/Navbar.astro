---
import { Cpu, Github, Linkedin, Coffee } from 'lucide-astro';

const menuItems = [
  { id: "specs", name: "Features", color: "text-neon-yellow" },
  { id: "how-it-works", name: "How it works", color: "text-neon-cyan" },
  { id: "benchmarks", name: "Benchmarks", color: "text-neon-yellow" },
  { id: "reliability", name: "Subagents", color: "text-neon-cyan" },
  { id: "sponsor", name: "Sponsor", color: "text-neon-yellow" },
  { id: "reviews", name: "Reviews", color: "text-neon-cyan" },
  { id: "deployment", name: "Changelog", color: "text-neon-yellow" },
  { id: "faq", name: "FAQ", color: "text-neon-cyan" },
];

const mobileItems = [...menuItems, { id: "pricing", name: "Plans", color: "text-[#ffff00]" }];
---

<nav id="main-nav" class="fixed top-0 w-full z-[300] bg-black/80 backdrop-blur-xl border-b border-[#ffff00]/20 px-6 py-3 transition-colors duration-300">
  <div class="max-w-7xl mx-auto flex justify-between items-center relative z-[600]">
    <a href="/" class="flex items-center gap-3 group cursor-pointer">
      <div class="w-10 h-10 bg-black border border-neon-yellow rounded flex items-center justify-center shadow-[0_0_15px_rgba(255,255,0,0.3)] group-hover:shadow-[0_0_20px_#ffff00] transition-all">
        <Cpu size={24} class="text-neon-yellow animate-pulse" />
      </div>
      <div class="flex flex-col">
        <span class="font-black text-xl tracking-tighter text-white leading-none glitch" data-text="lui.z">lui.z</span>
      </div>
    </a>
    
    <div class="flex items-center gap-4 lg:gap-8">
      {/* Desktop Links - Horizontal List with Separators */}
      <div class="hidden md:flex items-center gap-3 lg:gap-4 text-[10px] font-black uppercase tracking-[0.15em] text-[#858585]">
         {menuItems.map((item, index) => (
           <div class="flex items-center gap-3 lg:gap-4">
             <a href={`#${item.id}`} class="hover:text-white transition-all py-1 border-b border-transparent hover:border-neon-yellow whitespace-nowrap">
               {item.name}
             </a>
             {index < menuItems.length - 1 && <span class="opacity-20 text-[#555]">|</span>}
           </div>
         ))}
      </div>

      <div class="hidden xl:flex flex-col items-end">
        <div class="flex items-center gap-2 px-3 py-1 border border-[#330033] rounded-full text-[8px] uppercase tracking-widest text-[#00ff00] bg-[#00ff00]/5">
          <div class="w-1.5 h-1.5 rounded-full bg-[#00ff00] animate-pulse shadow-[0_0_8px_#00ff00]"></div>
          Available
        </div>
      </div>

      <a href="#pricing" class="relative group px-4 sm:px-6 py-2 bg-black border border-neon-yellow text-neon-yellow text-[10px] sm:text-xs font-black uppercase tracking-widest overflow-hidden hover:text-black transition-colors duration-300 shrink-0">
        <div class="absolute inset-0 bg-neon-yellow translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-300"></div>
        <span class="relative z-10 uppercase font-black">GET STARTED</span>
      </a>

      {/* Sandwich Menu Toggle - Mobile Only */}
      <button id="menu-toggle" class="md:hidden relative w-10 h-10 flex items-center justify-center text-white hover:text-neon-yellow transition-colors group z-[700]">
         <div class="space-y-1.5 pointer-events-none">
            <div class="w-6 h-0.5 bg-current transition-all group-[.open]:rotate-45 group-[.open]:translate-y-2"></div>
            <div class="w-6 h-0.5 bg-current transition-all group-[.open]:opacity-0"></div>
            <div class="w-6 h-0.5 bg-current transition-all group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></div>
         </div>
      </button>
    </div>
  </div>
</nav>

{/* Fullscreen Mobile Menu - Optimized Centering & Spacing */}
<div id="nav-menu" class="md:hidden fixed inset-0 bg-black z-[400] translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] overflow-y-auto">
  <div class="absolute inset-0 cyber-grid opacity-20 pointer-events-none"></div>
  
  <div class="flex flex-col items-center justify-center min-h-screen py-16 px-6">
    <div class="flex flex-col items-center w-full relative z-10">
      {mobileItems.map((item) => (
        <a href={`#${item.id}`} class="nav-link w-full py-3.5 border-b border-white/5 flex flex-col items-center group hover:bg-white/[0.02] transition-all first:border-t">
           <span class="text-xl font-black uppercase tracking-[0.2em] text-[#858585] group-hover:text-white transition-colors">{item.name}</span>
        </a>
      ))}
    </div>

    <div class="mt-8 pt-8 border-t border-white/5 w-full max-w-xs text-center flex flex-col items-center z-10 shrink-0">
       <div class="flex gap-10 text-[#444]">
          <a href="https://github.com/luiz1361" target="_blank" class="hover:text-neon-yellow transition-colors">
            <Github size={24} strokeWidth={1.5} />
          </a>
          <a href="https://linkedin.com/in/luiz1361" target="_blank" class="hover:text-neon-cyan transition-colors">
            <Linkedin size={24} strokeWidth={1.5} />
          </a>
          <a href="https://buymeacoffee.com/luiz1361" target="_blank" class="hover:text-neon-yellow transition-colors">
            <Coffee size={24} strokeWidth={1.5} />
          </a>
       </div>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('nav-menu');
  const nav = document.getElementById('main-nav');
  const links = document.querySelectorAll('.nav-link');

  function toggleMenu() {
    const isOpen = toggle?.classList.toggle('open');
    menu?.classList.toggle('translate-x-full');
    document.body.classList.toggle('overflow-hidden');
    
    if (isOpen) {
      nav?.classList.remove('bg-black/80');
      nav?.classList.add('bg-black');
    } else {
      nav?.classList.remove('bg-black');
      nav?.classList.add('bg-black/80');
    }
  }

  function closeMenu() {
    toggle?.classList.remove('open');
    menu?.classList.add('translate-x-full');
    document.body.classList.remove('overflow-hidden');
    nav?.classList.remove('bg-black');
    nav?.classList.add('bg-black/80');
  }

  toggle?.addEventListener('click', toggleMenu);

  links.forEach(link => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMenu();
    }
  });
</script>