---
import { Cpu, Zap, Activity } from '@lucide/astro';
---

<nav class="fixed top-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-[#330033] px-6 py-4">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-[#ff00ff] rounded flex items-center justify-center">
        <Cpu size={20} class="text-black" />
      </div>
      <span class="font-bold text-xl tracking-tighter text-[#ff00ff]">LUIZFCM<span class="text-[#00ffff]">-3.6</span></span>
    </div>
    
    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="#specs" class="hover:text-[#ff00ff] transition-colors">Features</a>
      <a href="#benchmarks" class="hover:text-[#00ffff] transition-colors">Benchmarks</a>
      <a href="#reliability" class="hover:text-[#ff00ff] transition-colors">Reliability</a>
      <a href="#sponsor" class="hover:text-[#00ffff] transition-colors">Sponsor</a>
      <a href="#deployment" class="hover:text-[#00ff00] transition-colors">Changelog</a>
      <a href="#pricing" class="hover:text-[#ffff00] transition-colors">Plans</a>
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center gap-2 px-3 py-1 border border-[#330033] rounded-full text-[10px] uppercase tracking-widest text-[#00ff00]">
        <div class="w-1.5 h-1.5 rounded-full bg-[#00ff00] animate-pulse"></div>
        Live Online
      </div>
      <a href="#pricing" class="bg-[#ff00ff] text-black px-4 py-1.5 rounded-md text-sm font-bold hover:shadow-[0_0_20px_#ff00ff] transition-all">
        Deploy
      </a>
    </div>
  </div>
</nav>