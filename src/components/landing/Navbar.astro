---
import { Cpu, Zap, Activity } from '@lucide/astro';
---

<nav class="fixed top-0 w-full z-[200] bg-black/80 backdrop-blur-xl border-b border-[#ff00ff]/20 px-6 py-3">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <div class="flex items-center gap-3 group cursor-pointer">
      <div class="w-10 h-10 bg-black border border-neon-pink rounded flex items-center justify-center shadow-[0_0_15px_rgba(255,0,255,0.3)] group-hover:shadow-[0_0_20px_#ff00ff] transition-all">
        <Cpu size={24} class="text-neon-pink animate-pulse" />
      </div>
      <div class="flex flex-col">
        <span class="font-black text-xl tracking-tighter text-white leading-none glitch" data-text="LUIZ">LUIZ</span>
        <span class="text-[8px] font-fira text-[#ff00ff] uppercase tracking-[0.3em]">Cyborg_Neural_Interface</span>
      </div>
    </div>
    
    <div class="hidden lg:flex items-center gap-8 text-[10px] font-black uppercase tracking-widest text-[#858585]">
      <a href="#specs" class="hover:text-neon-pink transition-colors py-1 border-b border-transparent hover:border-neon-pink">01_Features</a>
      <a href="#benchmarks" class="hover:text-neon-cyan transition-colors py-1 border-b border-transparent hover:border-neon-cyan">02_Benchmarks</a>
      <a href="#reliability" class="hover:text-neon-pink transition-colors py-1 border-b border-transparent hover:border-neon-pink">03_Reliability</a>
      <a href="#sponsor" class="hover:text-neon-cyan transition-colors py-1 border-b border-transparent hover:border-neon-cyan">04_Sponsor</a>
      <a href="#deployment" class="hover:text-[#00ff00] transition-colors py-1 border-b border-transparent hover:border-[#00ff00]">05_Changelog</a>
      <a href="#pricing" class="hover:text-[#ffff00] transition-colors py-1 border-b border-transparent hover:border-[#ffff00]">06_Plans</a>
    </div>

    <div class="flex items-center gap-6">
      <div class="hidden sm:flex flex-col items-end">
        <div class="flex items-center gap-2 px-3 py-1 border border-[#330033] rounded-full text-[8px] uppercase tracking-widest text-[#00ff00] bg-[#00ff00]/5">
          <div class="w-1.5 h-1.5 rounded-full bg-[#00ff00] animate-pulse shadow-[0_0_8px_#00ff00]"></div>
          Core_Online
        </div>
      </div>
      <a href="#pricing" class="relative group px-6 py-2 bg-black border border-neon-pink text-neon-pink text-xs font-black uppercase tracking-widest overflow-hidden hover:text-black transition-colors duration-300">
        <div class="absolute inset-0 bg-neon-pink translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-300"></div>
        <span class="relative z-10">Deploy</span>
      </a>
    </div>
  </div>
</nav>