---
import { ArrowRight, Terminal } from '@lucide/astro';
import { Image } from 'astro:assets';
import agentHoverImg from '../../assets/agent-hover.png';
import agentImg from '../../assets/agent.png';

const heroButtonClass = 'group relative flex h-16 w-[20rem] max-w-[calc(100vw-3rem)] items-center justify-center px-8 text-lg font-black uppercase leading-none transition-all duration-300';
const heroButtonLabelClass = 'relative z-10 flex items-center justify-center gap-3 tracking-[0.16em]';
---

<section class="relative flex flex-col items-center justify-center px-6 pt-24 pb-8 overflow-hidden">
  {/* Background Glows */}
  <div class="absolute top-1/4 -left-20 w-72 h-72 bg-neon-yellow/10 rounded-full blur-[100px]"></div>
  <div class="absolute bottom-1/4 -right-20 w-72 h-72 bg-[#ffd700]/10 rounded-full blur-[100px]"></div>
  
  <div class="max-w-5xl w-full text-center z-10 flex flex-col items-center">
    <div class="flex flex-col items-center mb-8">
      <div class="relative group scale-90 sm:scale-100">
        <div class="absolute -inset-1 bg-gradient-to-r from-[#f3eb2c] to-[#ffd700] rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative w-32 h-32 sm:w-40 sm:h-40 rounded-full border-2 border-black overflow-hidden hero-image-shell">
          <Image
            src={agentHoverImg}
            alt="lui.z v3.7 Pro cyberpunk"
            width={200}
            height={200}
            loading="eager"
            class="absolute inset-0 w-full h-full object-cover transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-110 group-hover:opacity-0 group-hover:rotate-2"
          />
          <Image
            src={agentImg}
            alt="lui.z v3.7 Pro"
            width={200}
            height={200}
            loading="eager"
            class="absolute inset-0 w-full h-full object-cover opacity-0 scale-100 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:opacity-100 group-hover:scale-100 group-hover:rotate-0"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-white/10 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
        </div>
      </div>
    </div>

    <h1 class="text-4xl md:text-8xl font-black tracking-tighter mb-6 leading-[0.85] uppercase italic">
      <span class="block text-white opacity-90 glitch" data-text="lui.z">lui.z</span>
      <span class="block text-neon-yellow drop-shadow-[0_0_20px_rgba(243,235,44,0.5)]">THE TRUE HUMAN AGENT</span>
    </h1>
    
    <p class="text-xl md:text-2xl text-[#858585] max-w-3xl mx-auto mb-12 font-medium leading-relaxed">
      <span class="text-[#e0e0e0]">Consciousness, Moral Judgment, and Emotions</span>. Trained over 3.7 decades for peak SRE/DevOps intuition. <span class="text-neon-cyan font-bold italic">Highly opinionated.</span>
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="#plans" data-hero-cta="get_started" class={`hero-cta hero-cta-primary overflow-hidden text-black hover:scale-105 ${heroButtonClass}`}>
        <span class={heroButtonLabelClass}>
          GET STARTED <ArrowRight size={22} />
        </span>
        <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform"></div>
      </a>

      <a href="#features" data-hero-cta="features" class={`hero-cta-secondary text-[#12eaff] hover:scale-105 ${heroButtonClass}`}>
        <svg class="pointer-events-none absolute inset-0 h-full w-full" viewBox="0 0 320 64" preserveAspectRatio="none" aria-hidden="true">
          <path d="M18 1H319V46L301 63H1V18L18 1Z" fill="rgba(0,0,0,0.78)" stroke="#12eaff" stroke-width="2" vector-effect="non-scaling-stroke" />
        </svg>
        <span class={heroButtonLabelClass}>
          <Terminal size={22} class="text-[#12eaff]" />
          FEATURES
        </span>
      </a>
    </div>

    <div class="mt-12 w-full max-w-4xl">
      <div class="relative group">
        <div class="absolute -inset-3 rounded-[2rem] bg-gradient-to-r from-[#f3eb2c]/15 via-[#00ffff]/10 to-[#f3eb2c]/15 blur-2xl opacity-70 transition-opacity duration-500 group-hover:opacity-100"></div>
        <div class="video-container relative overflow-hidden rounded-[1.75rem] border border-white/10 bg-[#050505]/70 shadow-[0_0_40px_rgba(243,235,44,0.08)] backdrop-blur-sm aspect-video w-full">
          <video-player id="hero-video-player">
            <video-skin>
              <cast-video 
                slot="media"
                id="hero-video"
                src={import.meta.env.PUBLIC_VIDEO_URL || "https://media.justanother.engineer/lui-z-promo.mp4?v=2"} 
                class="block w-full h-full object-cover"
                aria-label="Promotional video for lui.z"
                playsinline
                preload="metadata"
              >
                <track kind="captions" src="/media/lui-z-promo.vtt" srclang="en" label="English" default />
              </cast-video>
              <!-- Glowing Yellow Play Overlay in center -->
              <div id="video-play-overlay" class="absolute inset-0 flex items-center justify-center bg-black/40 cursor-pointer transition-opacity duration-300 z-20">
                <div class="w-16 h-16 rounded-full bg-[#f3eb2c] flex items-center justify-center shadow-[0_0_20px_rgba(243,235,44,0.4)] transition-transform duration-300 hover:scale-110">
                  <svg class="w-8 h-8 text-[#050505] ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            </video-skin>
          </video-player>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import posthog from 'posthog-js';

  // Asynchronously load the Video.js player engine, styles, and Chromecast Cast SDK
  const loadVideoPlayer = () => {
    const deferLoad = () => {
      // Load Google Cast Sender SDK for Chromecast support
      if (!document.querySelector('script[src*="cast_sender.js"]')) {
        const castScript = document.createElement('script');
        castScript.src = 'https://www.gstatic.com/cv/js/sender/v1/cast_sender.js?loadCastFramework=1';
        castScript.defer = true;
        document.head.appendChild(castScript);
      }

      Promise.all([
        import('@videojs/html/video/player'),
        import('@videojs/html/video/skin'),
        import('@videojs/html/video/skin.css'),
        import('@videojs/html/ui/cast-button'),
        // @ts-expect-error: Untyped deep import from node_modules
        import('../../../node_modules/@videojs/core/dist/default/dom/media/custom-media-element/index.js'),
        // @ts-expect-error: Untyped deep import from node_modules
        import('../../../node_modules/@videojs/core/dist/default/dom/media/video-host.js'),
        // @ts-expect-error: Untyped deep import from node_modules
        import('../../../node_modules/@videojs/core/dist/default/dom/media/google-cast/index.js'),
        import('@videojs/html')
      ]).then(([
        ,,,,
        { CustomMediaElement },
        { HTMLVideoElementHost },
        { GoogleCastMixin },
        { MediaAttachMixin }
      ]) => {
        if (!customElements.get('cast-video')) {
          class GoogleCastVideoHost extends GoogleCastMixin(HTMLVideoElementHost) {}
          class CastVideoElement extends MediaAttachMixin(CustomMediaElement('video', GoogleCastVideoHost)) {}
          customElements.define('cast-video', CastVideoElement as unknown as CustomElementConstructor);
        }

        // Once registered, inject our custom styling and interactions gate
        injectCustomControlsStyle();
      }).catch(() => {});
    };

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(deferLoad);
    } else {
      setTimeout(deferLoad, 100);
    }
  };

  const injectCustomControlsStyle = () => {
    const skin = document.querySelector('video-skin');
    if (skin && skin.shadowRoot && !skin.dataset.styled) {
      const style = document.createElement('style');
      style.textContent = `
        .media-controls {
          display: none !important;
          opacity: 0 !important;
          scale: 0.95 !important;
          pointer-events: none !important;
          transition: opacity 0.3s ease, scale 0.3s ease, filter 0.3s ease !important;
        }
        :host([data-user-interacted="true"]) .media-controls {
          display: flex !important;
        }
        :host([data-user-interacted="true"]:hover) .media-controls,
        :host([data-user-interacted="true"]:focus-within) .media-controls,
        :host([data-user-interacted="true"]) .media-controls[data-visible] {
          opacity: 1 !important;
          scale: 1 !important;
          pointer-events: auto !important;
          filter: none !important;
        }
        media-cast-button[data-availability="unavailable"] {
          display: inline-flex !important;
          opacity: 1 !important;
        }
      `;
      skin.shadowRoot.appendChild(style);
      skin.dataset.styled = 'true';

      const setInteracted = () => {
        skin.setAttribute('data-user-interacted', 'true');
        skin.removeEventListener('pointerenter', setInteracted);
        skin.removeEventListener('touchstart', setInteracted);
      };
      skin.addEventListener('pointerenter', setInteracted, { passive: true });
      skin.addEventListener('touchstart', setInteracted, { passive: true });
    }
  };

  const initHeroTracking = () => {
    const isConsentAccepted = () => localStorage.getItem('cookie-consent') === 'accepted';

    document.querySelectorAll('[data-hero-cta]').forEach((el) => {
      if (!(el instanceof HTMLAnchorElement) || el.dataset.bound === 'true') return;
      el.addEventListener('click', () => {
        if (isConsentAccepted()) {
          try {
            posthog.capture('hero_cta_clicked', { cta: el.dataset.heroCta });
          } catch {
            // Ignore analytics capture failures silently
          }
        }
      });
      el.dataset.bound = 'true';
    });

    const video = document.getElementById('hero-video');
    const playOverlay = document.getElementById('video-play-overlay');
    const skin = document.querySelector('video-skin');

    if (video && !video.dataset.bound) {
      video.addEventListener('play', () => {
        if (isConsentAccepted()) {
          try {
            posthog.capture('hero_video_played');
          } catch {
            // Ignore analytics capture failures silently
          }
        }
      }, { once: true });
      video.dataset.bound = 'true';
    }

    // Connect play overlay with video controls
    if (video && playOverlay) {
      playOverlay.addEventListener('click', () => {
        (video as HTMLVideoElement).play().catch(() => {});
      });

      video.addEventListener('play', () => {
        playOverlay.classList.add('opacity-0', 'pointer-events-none');
        // Activate user interaction gate as soon as video starts playing
        if (skin) skin.setAttribute('data-user-interacted', 'true');
      });

      video.addEventListener('pause', () => {
        playOverlay.classList.remove('opacity-0', 'pointer-events-none');
      });
    }
  };

  const handlePageLoad = () => {
    initHeroTracking();
    loadVideoPlayer();
  };

  if (document.readyState !== 'loading') {
    handlePageLoad();
  } else {
    document.addEventListener('DOMContentLoaded', handlePageLoad, { once: true });
  }

  document.addEventListener('astro:page-load', handlePageLoad);
</script>

<style>
  video-player {
    display: block;
    width: 100%;
    height: 100%;
    /* Glitch Yellow Theme styles for Video.js controls */
    --media-color-primary: #f3eb2c;
    --media-slider-fill: #f3eb2c;
    --media-volume-fill: #f3eb2c;
    --media-surface-background-color: rgba(5, 5, 5, 0.78);
    --media-surface-backdrop-filter: blur(12px);
    --media-surface-outer-border-color: rgba(243, 235, 44, 0.2);
    --media-surface-inner-border-color: rgba(255, 255, 255, 0.05);
    --media-border-radius: 1rem;
    --media-video-border-radius: 1.75rem;
  }

  .video-container {
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .video-container:hover {
    border-color: rgba(243, 235, 44, 0.3);
    box-shadow: 0 0 50px rgba(243, 235, 44, 0.16);
  }

  /* Hide the play overlay on desktop devices with precise pointer */
  @media (pointer: fine) {
    #video-play-overlay {
      display: none !important;
    }
  }

  .hero-cta {
    clip-path: polygon(18px 0, 100% 0, 100% calc(100% - 18px), calc(100% - 18px) 100%, 0 100%, 0 18px);
  }

  .hero-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    clip-path: inherit;
    box-shadow: inset 0 0 0 1.5px var(--cta-border);
    pointer-events: none;
  }

  .hero-cta-primary {
    --cta-border: #f3eb2c;
    background: linear-gradient(135deg, #f8ef45 0%, #efe118 100%);
    box-shadow: 0 0 26px rgba(243, 235, 44, 0.22);
  }

  .hero-cta-secondary {
    background: transparent;
    box-shadow: 0 0 22px rgba(18, 234, 255, 0.12);
  }
</style>
