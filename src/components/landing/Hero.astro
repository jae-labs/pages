---
import { ArrowRight, Terminal } from '@lucide/astro';
---

<section class="relative flex flex-col items-center justify-center px-6 pt-24 pb-8 overflow-hidden">
  {/* Background Glows */}
  <div class="absolute top-1/4 -left-20 w-72 h-72 bg-neon-pink/10 rounded-full blur-[100px]"></div>
  <div class="absolute bottom-1/4 -right-20 w-72 h-72 bg-neon-cyan/10 rounded-full blur-[100px]"></div>
  
  <div class="max-w-5xl w-full text-center z-10 flex flex-col items-center">
    <div class="flex flex-col items-center mb-8">
      <div class="relative group scale-90 sm:scale-100">
        <div class="absolute -inset-1 bg-gradient-to-r from-neon-pink to-neon-cyan rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
        <img src="/agent.png" alt="LuizFCM 3.6" class="relative w-32 h-32 sm:w-40 sm:h-40 rounded-full border-2 border-black object-cover" />
      </div>
    </div>

    <h1 class="text-4xl md:text-8xl font-black tracking-tighter mb-6 leading-[0.85] uppercase italic">
      <span class="block text-white opacity-90 glitch" data-text="LUIZ">LUIZ</span>
      <span class="block text-neon-pink drop-shadow-[0_0_20px_rgba(255,0,255,0.5)]">TRUE AGI</span>
    </h1>
    
    <p class="text-lg md:text-xl text-[#858585] max-w-2xl mx-auto mb-10 font-medium leading-relaxed">
      <span class="text-[#e0e0e0]">Consciousness, Moral Judgment, and Emotions</span>. Trained over 3.6 decades for peak SRE/DevOps intuition. <span class="text-neon-cyan font-bold italic">Highly opinionated.</span>
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#pricing" class="group relative px-8 py-3 bg-neon-pink text-black font-black uppercase tracking-widest rounded-lg overflow-hidden transition-all hover:scale-105 text-sm">
        <span class="relative z-10 flex items-center gap-2">
          Deploy <ArrowRight size={18} />
        </span>
        <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform"></div>
      </a>
      
      <a href="#specs" class="flex items-center gap-3 px-8 py-3 border border-[#330033] rounded-lg font-bold hover:bg-[#111] transition-all text-sm uppercase">
        <Terminal size={18} class="text-neon-cyan" />
        FEATURES
      </a>
    </div>
  </div>
</section>