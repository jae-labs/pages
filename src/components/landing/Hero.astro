---
import { ArrowRight, Terminal } from '@lucide/astro';
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-20 overflow-hidden">
  {/* Background Glows */}
  <div class="absolute top-1/4 -left-20 w-96 h-96 bg-[#ff00ff]/10 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-[#00ffff]/10 rounded-full blur-[120px]"></div>
  
  <div class="max-w-4xl w-full text-center z-10">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#ff00ff]/30 bg-[#ff00ff]/5 mb-8 animate-bounce">
      <span class="text-[10px] font-bold tracking-[0.2em] text-[#ff00ff] uppercase">V1.0.0 Stable Release</span>
    </div>
    
    <h1 class="text-5xl md:text-8xl font-black tracking-tighter mb-8 leading-[0.9]">
      <span class="block text-white">THE NEXT-GEN</span>
      <span class="block text-neon-pink">HUMAN AGENT</span>
    </h1>
    
    <p class="text-xl md:text-2xl text-[#858585] max-w-2xl mx-auto mb-12 font-medium">
      Zero latency. Fully autonomous. <span class="text-[#e0e0e0]">On-prem hardware included.</span> The first biological solution for your digital bottlenecks.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="#pricing" class="group relative px-8 py-4 bg-neon-pink text-black font-black uppercase tracking-widest rounded-lg overflow-hidden transition-all hover:scale-105">
        <span class="relative z-10 flex items-center gap-2">
          Provision Agent <ArrowRight size={20} />
        </span>
        <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform"></div>
      </a>
      
      <a href="#specs" class="flex items-center gap-3 px-8 py-4 border border-[#330033] rounded-lg font-bold hover:bg-[#111] transition-all">
        <Terminal size={20} class="text-[#00ffff]" />
        View Technical Specs
      </a>
    </div>
  </div>

  {/* Terminal Bar Simulation at bottom */}
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 w-full max-w-lg px-6">
    <div class="bg-black/40 backdrop-blur-sm border border-[#330033] rounded-lg p-3 font-fira text-[10px] flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-[#ff00ff]">$</span>
        <span class="text-[#858585]">agent --status</span>
      </div>
      <div class="flex gap-4">
        <span class="text-[#00ff00]">UPTIME: 99.9%</span>
        <span class="text-[#00ffff]">LATENCY: 50ms</span>
      </div>
    </div>
  </div>
</section>