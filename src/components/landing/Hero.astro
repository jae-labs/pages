---
import { ArrowRight, Terminal } from '@lucide/astro';
---

<section class="relative flex flex-col items-center justify-center px-6 pt-24 pb-8 overflow-hidden">
  {/* Background Glows */}
  <div class="absolute top-1/4 -left-20 w-72 h-72 bg-neon-yellow/10 rounded-full blur-[100px]"></div>
  <div class="absolute bottom-1/4 -right-20 w-72 h-72 bg-neon-cyan/10 rounded-full blur-[100px]"></div>
  
  <div class="max-w-5xl w-full text-center z-10 flex flex-col items-center">
    <div class="flex flex-col items-center mb-8">
      <div class="relative group scale-90 sm:scale-100">
        <div class="absolute -inset-1 bg-gradient-to-r from-neon-yellow to-neon-cyan rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
        <img src="/agent.png" alt="lui.z v3.6 Pro" class="relative w-32 h-32 sm:w-40 sm:h-40 rounded-full border-2 border-black object-cover" />
      </div>
    </div>

    <h1 class="text-4xl md:text-8xl font-black tracking-tighter mb-6 leading-[0.85] uppercase italic">
      <span class="block text-white opacity-90 glitch" data-text="lui.z">lui.z</span>
      <span class="block text-neon-yellow drop-shadow-[0_0_20px_rgba(255,255,0,0.5)]">TRUE HUMAN AGENT</span>
    </h1>
    
    <p class="text-xl md:text-2xl text-[#858585] max-w-3xl mx-auto mb-12 font-medium leading-relaxed">
      <span class="text-[#e0e0e0]">Consciousness, Moral Judgment, and Emotions</span>. Trained over 3.6 decades for peak SRE/DevOps intuition. <span class="text-neon-cyan font-bold italic">Highly opinionated.</span>
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="#pricing" class="group relative px-10 py-4 bg-neon-yellow text-black font-black uppercase tracking-widest rounded-lg overflow-hidden transition-all hover:scale-105 text-base">
        <span class="relative z-10 flex items-center gap-2">
          GET STARTED <ArrowRight size={22} />
        </span>
        <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform"></div>
      </a>
      
      <a href="#specs" class="flex items-center gap-3 px-10 py-4 border border-[#330033] rounded-lg font-black hover:bg-[#111] transition-all text-base uppercase">
        <Terminal size={22} class="text-neon-cyan" />
        FEATURES
      </a>
    </div>
  </div>
</section>