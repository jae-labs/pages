---
import { Coffee } from '@lucide/astro';
import GitHubIcon from '../icons/GitHubIcon.astro';
import LinkedInIcon from '../icons/LinkedInIcon.astro';
import SlackIcon from '../icons/SlackIcon.astro';
import PingdomIcon from '../icons/PingdomIcon.astro';
---

<footer class="py-12 border-t border-[#f3eb2c]/20 bg-[#050505] px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col items-center gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex items-center justify-center gap-2 text-center lg:justify-start lg:text-left">
        <span class="font-bold text-xl tracking-tighter text-[#f3eb2c]">lui.z</span>
        <span class="text-[10px] xl:text-xs text-[#999] font-fira ml-4">© 2026 lui.z</span>
      </div>

      <p class="max-w-3xl text-center text-[10px] xl:text-[11px] 2xl:text-xs leading-relaxed text-[#999] lg:flex-1 lg:text-left">
        <span class="font-fira font-bold uppercase tracking-[0.24em] text-[#f3eb2c]">Disclaimer</span>
        <span class="ml-2">
          The views, content, jokes, and questionable benchmarks here are entirely my own and do not represent any current or former employer. Reviews and deployment entries are real and based on information shared on my LinkedIn profile.
        </span>
      </p>

      <div class="flex justify-center gap-2 text-neutral-400">
        <a href="https://github.com/luiz1361" class="relative group inline-flex items-center justify-center p-3 hover:text-[#f3eb2c] transition-colors" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile">
          <GitHubIcon size="100%" class="w-[20px] h-[20px] xl:w-[22px] xl:h-[22px] 2xl:w-[24px] 2xl:h-[24px]" />
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center pointer-events-none z-[999]" role="tooltip">
            <div class="bg-[#0f0f0f] border border-white/10 rounded-md px-2 py-1 text-[10px] text-[#bbb] shadow-[0_4px_15px_rgba(0,0,0,0.5)] whitespace-nowrap">
              GitHub
            </div>
            <div class="w-1.5 h-1.5 bg-[#0f0f0f] border-r border-b border-white/10 rotate-45 -mt-[3px]"></div>
          </div>
        </a>

        <a href="https://join.slack.com/t/justanotherengineer/shared_invite/zt-23m74nwgy-STbP1b2nskLTz5Ql3NRtTQ" class="relative group inline-flex items-center justify-center p-3 hover:text-[#f3eb2c] transition-colors" target="_blank" rel="noopener noreferrer" aria-label="Slack Community Invite">
          <SlackIcon size="100%" class="w-[20px] h-[20px] xl:w-[22px] xl:h-[22px] 2xl:w-[24px] 2xl:h-[24px]" />
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center pointer-events-none z-[999]" role="tooltip">
            <div class="bg-[#0f0f0f] border border-white/10 rounded-md px-2 py-1 text-[10px] text-[#bbb] shadow-[0_4px_15px_rgba(0,0,0,0.5)] whitespace-nowrap">
              Slack
            </div>
            <div class="w-1.5 h-1.5 bg-[#0f0f0f] border-r border-b border-white/10 rotate-45 -mt-[3px]"></div>
          </div>
        </a>

        <a href="https://www.linkedin.com/in/luiz1361/" class="relative group inline-flex items-center justify-center p-3 hover:text-[#00ffff] transition-colors" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn Profile">
          <LinkedInIcon size="100%" class="w-[20px] h-[20px] xl:w-[22px] xl:h-[22px] 2xl:w-[24px] 2xl:h-[24px]" />
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center pointer-events-none z-[999]" role="tooltip">
            <div class="bg-[#0f0f0f] border border-white/10 rounded-md px-2 py-1 text-[10px] text-[#bbb] shadow-[0_4px_15px_rgba(0,0,0,0.5)] whitespace-nowrap">
              LinkedIn
            </div>
            <div class="w-1.5 h-1.5 bg-[#0f0f0f] border-r border-b border-white/10 rotate-45 -mt-[3px]"></div>
          </div>
        </a>

        <a href="https://buymeacoffee.com/luiz1361" class="relative group inline-flex items-center justify-center p-3 hover:text-[#f3eb2c] transition-colors" target="_blank" rel="noopener noreferrer" aria-label="Buy Me A Coffee">
          <Coffee size="100%" class="w-[20px] h-[20px] xl:w-[22px] xl:h-[22px] 2xl:w-[24px] 2xl:h-[24px]" stroke-width={1.5} />
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center pointer-events-none z-[999]" role="tooltip">
            <div class="bg-[#0f0f0f] border border-white/10 rounded-md px-2 py-1 text-[10px] text-[#bbb] shadow-[0_4px_15px_rgba(0,0,0,0.5)] whitespace-nowrap">
              Buy Me A Coffee
            </div>
            <div class="w-1.5 h-1.5 bg-[#0f0f0f] border-r border-b border-white/10 rotate-45 -mt-[3px]"></div>
          </div>
        </a>

        <a href="https://stats.pingdom.com/ieq3v42yov76/4989186" class="relative group inline-flex items-center justify-center p-3 hover:text-[#f3eb2c] transition-colors" target="_blank" rel="noopener noreferrer" aria-label="Pingdom Public Status Page">
          <PingdomIcon size="100%" class="w-[20px] h-[20px] xl:w-[22px] xl:h-[22px] 2xl:w-[24px] 2xl:h-[24px]" />
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center pointer-events-none z-[999]" role="tooltip">
            <div class="bg-[#0f0f0f] border border-white/10 rounded-md px-2 py-1 text-[10px] text-[#bbb] shadow-[0_4px_15px_rgba(0,0,0,0.5)] whitespace-nowrap">
              Pingdom Status
            </div>
            <div class="w-1.5 h-1.5 bg-[#0f0f0f] border-r border-b border-white/10 rotate-45 -mt-[3px]"></div>
          </div>
        </a>
      </div>
    </div>
  </div>
</footer>
