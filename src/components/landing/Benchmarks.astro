---
const benchmarks = [
  { 
    metric: "BIO-LOGIC (Biological Reasoner)", 
    luiz: 98, 
    luiz_caff: 100, 
    g5: 42,
    c4: 38,
    oplus: 45,
    snet: 40
  },
  { 
    metric: "N-DEEP (Neural Data Patterning)", 
    luiz: 95, 
    luiz_caff: 99, 
    g5: 65,
    c4: 58,
    oplus: 68,
    snet: 62
  },
  { 
    metric: "MTTR-INFRA (Incident Reflex)", 
    luiz: 100, 
    luiz_caff: 100, 
    g5: 12,
    c4: 15,
    oplus: 20,
    snet: 18
  },
  { 
    metric: "CTX-BUFFER (Dynamic Memory)", 
    luiz: 88, 
    luiz_caff: 94, 
    g5: 70,
    c4: 75,
    oplus: 78,
    snet: 72
  },
  { 
    metric: "ZERO-SHIRT (Creative Output)", 
    luiz: 96, 
    luiz_caff: 98, 
    g5: 55,
    c4: 60,
    oplus: 64,
    snet: 58
  }
];

const colors = {
  luiz: "bg-[#ffff00]",
  luiz_caff: "bg-[#00ffff]",
  g5: "bg-[#333333]",
  c4: "bg-[#222222]",
  oplus: "bg-[#444444]",
  snet: "bg-[#111111]"
};
---

<section id="benchmarks" class="py-12 px-6 relative border-y border-white/5 bg-black">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="BENCHMARKS">BENCHMARKS</h3>
    </div>

    <div class="space-y-12 bg-black border border-white/10 rounded-3xl p-8 shadow-[0_0_50px_rgba(255,255,0,0.05)]">
      {benchmarks.map((b) => (
        <div class="group">
          <div class="flex justify-between items-end mb-4">
            <h4 class="text-white font-bold text-[10px] uppercase tracking-widest leading-none">{b.metric}</h4>
            <div class="flex gap-4 text-[10px] font-fira uppercase leading-none">
              <span class="text-[#ffff00]">3.6: {b.luiz}%</span>
              <span class="text-[#00ffff]">3.6 Caff: {b.luiz_caff}%</span>
            </div>
          </div>
          
          <div class="space-y-3">
            {/* Luiz 3.6 Caffeinated - The Overclocker */}
            <div class="relative h-4 bg-white/5 rounded-full overflow-hidden">
              <div 
                class="absolute inset-y-0 left-0 bg-[#00ffff] shadow-[0_0_15px_#00ffff] transition-all duration-1000 ease-out group-hover:scale-x-105 origin-left"
                style={{ width: `${b.luiz_caff}%` }}
              >
                <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/20 animate-pulse"></div>
              </div>
            </div>

            {/* Luiz 3.6 - Standard */}
            <div class="relative h-2.5 bg-white/5 rounded-full overflow-hidden">
              <div 
                class="absolute inset-y-0 left-0 bg-[#ffff00] transition-all duration-1000 delay-100 ease-out"
                style={{ width: `${b.luiz}%` }}
              ></div>
            </div>

            {/* Competitors */}
            <div class="flex gap-2 pt-1">
               <div class="flex-1 h-1 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-[#333333]" style={{ width: `${b.g5}%` }}></div>
               </div>
               <div class="flex-1 h-1 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-[#222222]" style={{ width: `${b.c4}%` }}></div>
               </div>
               <div class="flex-1 h-1 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-[#444444]" style={{ width: `${b.oplus}%` }}></div>
               </div>
               <div class="flex-1 h-1 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-[#111111]" style={{ width: `${b.snet}%` }}></div>
               </div>
            </div>
          </div>
        </div>
      ))}

      {/* Legend */}
      <div class="pt-8 border-t border-white/10 flex flex-wrap justify-center gap-6 text-[8px] font-fira uppercase tracking-widest">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[#00ffff] shadow-[0_0_5px_#00ffff]"></div>
          <span class="text-white">Luiz 3.6 (Caff)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[#ffff00]"></div>
          <span class="text-white">Luiz 3.6 (Base)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[#444]"></div>
          <span class="text-[#555]">Aura-Plus v1</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[#333]"></div>
          <span class="text-[#555]">G-Model 5 (Sim)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[#222]"></div>
          <span class="text-[#555]">C-Model 4 (Draft)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[#111]"></div>
          <span class="text-[#555]">Lumina-Net v2</span>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center text-[#ffff00]/60 text-[10px] italic">
      * All benchmarks are part of a fictional marketing parody. No biological units were actually measured for this data.
    </div>
  </div>
</section>