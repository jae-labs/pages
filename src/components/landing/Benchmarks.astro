---
const benchmarks = [
  { 
    metric: "BIO-LOGIC", 
    desc: "Biological Reasoner",
    luiz: 100, 
    competitors: [
      { name: "A-Plus", val: 45 },
      { name: "G-Model 5", val: 42 },
      { name: "C-Model 4", val: 38 },
      { name: "L-Net v2", val: 40 }
    ]
  },
  { 
    metric: "N-DEEP", 
    desc: "Neural Data Patterning",
    luiz: 99, 
    competitors: [
      { name: "A-Plus", val: 68 },
      { name: "G-Model 5", val: 65 },
      { name: "C-Model 4", val: 58 },
      { name: "L-Net v2", val: 62 }
    ]
  },
  { 
    metric: "MTTR-INFRA", 
    desc: "Incident Reflex",
    luiz: 100, 
    competitors: [
      { name: "A-Plus", val: 20 },
      { name: "G-Model 5", val: 12 },
      { name: "C-Model 4", val: 15 },
      { name: "L-Net v2", val: 18 }
    ]
  },
  { 
    metric: "CTX-BUFFER", 
    desc: "Dynamic Memory",
    luiz: 94, 
    competitors: [
      { name: "A-Plus", val: 78 },
      { name: "G-Model 5", val: 70 },
      { name: "C-Model 4", val: 75 },
      { name: "L-Net v2", val: 72 }
    ]
  },
  { 
    metric: "ZERO-SHIRT", 
    desc: "Creative Output",
    luiz: 98, 
    competitors: [
      { name: "A-Plus", val: 64 },
      { name: "G-Model 5", val: 55 },
      { name: "C-Model 4", val: 60 },
      { name: "L-Net v2", val: 58 }
    ]
  }
];
---

<section id="benchmarks" class="py-12 px-6 relative border-y border-white/5 bg-black">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="BENCHMARKS">BENCHMARKS</h3>
    </div>

    <div class="bg-[#050505]/40 backdrop-blur-sm border border-white/10 rounded-2xl overflow-hidden shadow-[0_0_50px_rgba(255,255,0,0.02)]">
      {/* Table Header */}
      <div class="grid grid-cols-12 gap-4 p-6 border-b border-white/10 bg-white/5 font-black text-[10px] uppercase tracking-[0.2em] text-[#555]">
        <div class="col-span-3">Technical Metric</div>
        <div class="col-span-7 px-4">Performance Comparison</div>
        <div class="col-span-2 text-right">lui.z v3.6 Pro</div>
      </div>

      <div class="divide-y divide-white/5">
        {benchmarks.map((b) => (
          <div class="grid grid-cols-12 gap-4 p-6 items-center group hover:bg-white/[0.02] transition-colors">
            {/* Metric Column */}
            <div class="col-span-3">
              <h4 class="text-white font-black text-xs tracking-tighter uppercase mb-1">{b.metric}</h4>
              <span class="text-[7px] font-fira text-[#444] uppercase tracking-widest">{b.desc}</span>
            </div>

            {/* Graph Column */}
            <div class="col-span-7 px-4 space-y-2">
              {/* lui.z Primary Bar */}
              <div class="relative h-2.5 bg-white/5 rounded-full overflow-hidden">
                <div 
                  class="absolute inset-y-0 left-0 bg-neon-yellow shadow-[0_0_15px_rgba(255,255,0,0.4)] transition-all duration-1000 ease-out origin-left group-hover:brightness-125"
                  style={{ width: `${b.luiz}%` }}
                >
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/10 animate-pulse"></div>
                </div>
              </div>

              {/* Competitor Bars Cluster */}
              <div class="flex gap-1 h-1">
                {b.competitors.map((comp) => (
                  <div class="flex-1 bg-white/5 rounded-full overflow-hidden" title={`${comp.name}: ${comp.val}%`}>
                    <div 
                      class="h-full bg-white/10 transition-all duration-1000 delay-300" 
                      style={{ width: `${comp.val}%` }}
                    ></div>
                  </div>
                ))}
              </div>
            </div>

            {/* Score Column */}
            <div class="col-span-2 text-right">
              <span class="text-xl font-black text-white font-fira">{b.luiz}%</span>
            </div>
          </div>
        ))}
      </div>

      {/* Legend Footer */}
      <div class="p-6 border-t border-white/10 bg-white/5 flex flex-wrap justify-center gap-8 text-[8px] font-fira uppercase tracking-widest">
        <div class="flex items-center gap-2">
          <div class="w-3 h-[1px] bg-neon-yellow shadow-[0_0_5px_#ffff00]"></div>
          <span class="text-white">lui.z v3.6 Pro</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-[1px] bg-white/20"></div>
          <span class="text-[#555]">Competitor Average (Silicon-Based)</span>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center text-neon-yellow/40 text-[10px] italic">
      * All benchmarks are part of a fictional marketing parody. No biological units were measured for this data.
    </div>
  </div>
</section>