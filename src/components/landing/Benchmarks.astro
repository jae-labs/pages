---
const benchmarks = [
  { 
    metric: "BIO-LOGIC", 
    desc: "Biological Reasoner",
    luiz: 100, 
    competitors: [
      { name: "Aura-Plus v1", val: 45 },
      { name: "G-Model 5 (Sim)", val: 42 },
      { name: "C-Model 4 (Draft)", val: 38 },
      { name: "Lumina-Net v2", val: 40 }
    ]
  },
  { 
    metric: "N-DEEP", 
    desc: "Neural Data Patterning",
    luiz: 99, 
    competitors: [
      { name: "Aura-Plus v1", val: 68 },
      { name: "G-Model 5 (Sim)", val: 65 },
      { name: "C-Model 4 (Draft)", val: 58 },
      { name: "Lumina-Net v2", val: 62 }
    ]
  },
  { 
    metric: "MTTR-INFRA", 
    desc: "Incident Reflex",
    luiz: 100, 
    competitors: [
      { name: "Aura-Plus v1", val: 20 },
      { name: "G-Model 5 (Sim)", val: 12 },
      { name: "C-Model 4 (Draft)", val: 15 },
      { name: "Lumina-Net v2", val: 18 }
    ]
  },
  { 
    metric: "CTX-BUFFER", 
    desc: "Dynamic Memory",
    luiz: 94, 
    competitors: [
      { name: "Aura-Plus v1", val: 78 },
      { name: "G-Model 5 (Sim)", val: 70 },
      { name: "C-Model 4 (Draft)", val: 75 },
      { name: "Lumina-Net v2", val: 72 }
    ]
  },
  { 
    metric: "ZERO-SHIRT", 
    desc: "Creative Output",
    luiz: 98, 
    competitors: [
      { name: "Aura-Plus v1", val: 64 },
      { name: "G-Model 5 (Sim)", val: 55 },
      { name: "C-Model 4 (Draft)", val: 60 },
      { name: "Lumina-Net v2", val: 58 }
    ]
  }
];
---

<section id="benchmarks" class="py-12 px-6 relative border-y border-white/5 bg-black">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="BENCHMARKS">BENCHMARKS</h3>
    </div>

    <div class="space-y-12">
      {benchmarks.map((b) => (
        <div class="group border border-white/10 bg-[#050505]/40 backdrop-blur-sm p-8 rounded-2xl overflow-hidden relative">
          
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
              <h4 class="text-2xl font-black text-white italic tracking-tighter uppercase leading-none mb-1">{b.metric}</h4>
              <span class="text-[8px] font-fira text-[#555] uppercase tracking-[0.3em]">{b.desc}</span>
            </div>
            <div class="flex gap-6 text-[10px] font-black uppercase">
               <div class="flex flex-col items-end">
                  <span class="text-neon-yellow leading-none mb-1">lui.z 3.6 Pro</span>
                  <span class="text-white text-xl font-fira">{b.luiz}%</span>
               </div>
            </div>
          </div>

          <div class="space-y-6">
            {/* Main Bar */}
            <div class="space-y-2">
               <div class="h-4 bg-white/5 rounded-full overflow-hidden relative group/bar border border-white/5">
                  <div 
                    class="absolute inset-y-0 left-0 bg-neon-yellow shadow-[0_0_20px_rgba(255,255,0,0.4)] transition-all duration-1000 ease-out origin-left group-hover/bar:brightness-125"
                    style={{ width: `${b.luiz}%` }}
                  >
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/10 animate-pulse"></div>
                  </div>
               </div>
            </div>

            {/* Competitor Grid */}
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-4 border-t border-white/5">
               {b.competitors.map((comp) => (
                 <div>
                    <div class="flex justify-between items-center mb-2">
                       <span class="text-[8px] text-[#555] font-black uppercase tracking-tight truncate mr-2">{comp.name}</span>
                       <span class="text-[9px] text-[#858585] font-fira">{comp.val}%</span>
                    </div>
                    <div class="h-1 bg-white/5 rounded-full overflow-hidden">
                       <div class="h-full bg-[#222] transition-all duration-1000 delay-300" style={{ width: `${comp.val}%` }}></div>
                    </div>
                 </div>
               ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center text-neon-yellow/40 text-[10px] italic">
      * All benchmarks are part of a fictional marketing parody. No biological units were actually measured for this data.
    </div>
  </div>
</section>