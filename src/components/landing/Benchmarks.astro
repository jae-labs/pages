---
const benchmarks = [
  { 
    metric: "BIO-LOGIC", 
    desc: "Biological Reasoner",
    models: [
      { name: "lui.z v3.6 Pro", val: 100, primary: true },
      { name: "Aura-Plus v1", val: 45 },
      { name: "G-Model 5 (Sim)", val: 42 },
      { name: "C-Model 4 (Draft)", val: 38 },
      { name: "Lumina-Net v2", val: 40 }
    ]
  },
  { 
    metric: "N-DEEP", 
    desc: "Neural Data Patterning",
    models: [
      { name: "lui.z v3.6 Pro", val: 99, primary: true },
      { name: "Aura-Plus v1", val: 68 },
      { name: "G-Model 5 (Sim)", val: 65 },
      { name: "C-Model 4 (Draft)", val: 58 },
      { name: "Lumina-Net v2", val: 62 }
    ]
  },
  { 
    metric: "MTTR-INFRA", 
    desc: "Incident Reflex",
    models: [
      { name: "lui.z v3.6 Pro", val: 100, primary: true },
      { name: "Aura-Plus v1", val: 20 },
      { name: "G-Model 5 (Sim)", val: 12 },
      { name: "C-Model 4 (Draft)", val: 15 },
      { name: "Lumina-Net v2", val: 18 }
    ]
  },
  { 
    metric: "CTX-BUFFER", 
    desc: "Dynamic Memory",
    models: [
      { name: "lui.z v3.6 Pro", val: 94, primary: true },
      { name: "Aura-Plus v1", val: 78 },
      { name: "G-Model 5 (Sim)", val: 70 },
      { name: "C-Model 4 (Draft)", val: 75 },
      { name: "Lumina-Net v2", val: 72 }
    ]
  },
  { 
    metric: "ZERO-SHIRT", 
    desc: "Creative Output",
    models: [
      { name: "lui.z v3.6 Pro", val: 98, primary: true },
      { name: "Aura-Plus v1", val: 64 },
      { name: "G-Model 5 (Sim)", val: 55 },
      { name: "C-Model 4 (Draft)", val: 60 },
      { name: "Lumina-Net v2", val: 58 }
    ]
  }
];
---

<section id="benchmarks" class="py-12 px-6 relative border-y border-white/5 bg-black">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="BENCHMARKS">BENCHMARKS</h3>
    </div>

    <div class="space-y-12">
      {benchmarks.map((b) => (
        <div class="group border border-white/10 bg-[#050505]/40 backdrop-blur-sm p-6 sm:p-8 rounded-2xl overflow-hidden relative">
          <div class="mb-8 border-b border-white/5 pb-4">
            <h4 class="text-2xl font-black text-white italic tracking-tighter uppercase leading-none mb-1">{b.metric}</h4>
            <span class="text-[8px] font-fira text-[#555] uppercase tracking-[0.3em]">{b.desc}</span>
          </div>

          <div class="space-y-4">
            {b.models.map((m) => (
              <div class="grid grid-cols-12 gap-4 items-center group/row">
                {/* Model Name */}
                <div class="col-span-4 md:col-span-3">
                  <span class={`text-[9px] font-black uppercase tracking-tight truncate ${m.primary ? 'text-neon-yellow' : 'text-[#555] group-hover/row:text-[#888] transition-colors'}`}>
                    {m.name}
                  </span>
                </div>

                {/* Graph Bar */}
                <div class="col-span-6 md:col-span-7">
                  <div class={`relative h-2 rounded-full overflow-hidden ${m.primary ? 'bg-white/5' : 'bg-white/[0.02]'}`}>
                    <div 
                      class={`absolute inset-y-0 left-0 transition-all duration-1000 ease-out origin-left ${m.primary ? 'bg-neon-yellow shadow-[0_0_15px_rgba(255,255,0,0.4)]' : 'bg-white/10 group-hover/row:bg-white/20'}`}
                      style={{ width: `${m.val}%` }}
                    >
                      {m.primary && (
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/10 animate-pulse"></div>
                      )}
                    </div>
                  </div>
                </div>

                {/* Score */}
                <div class="col-span-2 text-right">
                  <span class={`text-xs font-black font-fira ${m.primary ? 'text-white text-base' : 'text-[#444] group-hover/row:text-[#666] transition-colors'}`}>
                    {m.val}%
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center text-neon-yellow/40 text-[10px] italic">
      * All benchmarks are part of a fictional marketing parody. No biological units were measured for this data.
    </div>
  </div>
</section>