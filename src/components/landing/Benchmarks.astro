---
const benchmarks = [
  { 
    metric: "Cognitive Intuition", 
    luiz: 98, 
    luiz_caff: 100, 
    gpt5: 42,
    claude: 38 
  },
  { 
    metric: "Incident MTTR (Normalized)", 
    luiz: 95, 
    luiz_caff: 99, 
    gpt5: 65,
    claude: 58 
  },
  { 
    metric: "Opinion Stability", 
    luiz: 100, 
    luiz_caff: 100, 
    gpt5: 12,
    claude: 15 
  },
  { 
    metric: "Context Retention", 
    luiz: 88, 
    luiz_caff: 94, 
    gpt5: 70,
    claude: 75 
  },
  { 
    metric: "Creativity (Zero-Shot)", 
    luiz: 96, 
    luiz_caff: 98, 
    gpt5: 55,
    claude: 60 
  }
];

const colors = {
  luiz: "bg-[#ffff00]",
  luiz_caff: "bg-[#00ffff]",
  gpt5: "bg-[#333333]",
  claude: "bg-[#222222]"
};
---

<section id="benchmarks" class="py-12 px-6 relative border-y border-white/5 bg-black">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="BENCHMARKS">BENCHMARKS</h3>
    </div>

    <div class="space-y-12 bg-black border border-[#330033] rounded-3xl p-8 shadow-[0_0_50px_rgba(255,255,0,0.05)]">
      {benchmarks.map((b) => (
        <div class="group">
          <div class="flex justify-between items-end mb-4">
            <h4 class="text-white font-bold text-sm uppercase tracking-wider">{b.metric}</h4>
            <div class="flex gap-4 text-[10px] font-fira uppercase">
              <span class="text-[#ffff00]">3.6: {b.luiz}%</span>
              <span class="text-[#00ffff]">3.6 Caff: {b.luiz_caff}%</span>
            </div>
          </div>
          
          <div class="space-y-3">
            {/* Luiz 3.6 Caffeinated - The Overclocker */}
            <div class="relative h-4 bg-white/5 rounded-full overflow-hidden">
              <div 
                class="absolute inset-y-0 left-0 bg-[#00ffff] shadow-[0_0_15px_#00ffff] transition-all duration-1000 ease-out group-hover:scale-x-105 origin-left"
                style={{ width: `${b.luiz_caff}%` }}
              >
                <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/20 animate-pulse"></div>
              </div>
            </div>

            {/* Luiz 3.6 - Standard */}
            <div class="relative h-2.5 bg-white/5 rounded-full overflow-hidden">
              <div 
                class="absolute inset-y-0 left-0 bg-[#ffff00] transition-all duration-1000 delay-100 ease-out"
                style={{ width: `${b.luiz}%` }}
              ></div>
            </div>

            {/* Competitors */}
            <div class="flex gap-4 pt-1">
               <div class="flex-1 h-1.5 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-[#333333]" style={{ width: `${b.gpt5}%` }}></div>
               </div>
               <div class="flex-1 h-1.5 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-[#222222]" style={{ width: `${b.claude}%` }}></div>
               </div>
            </div>
          </div>
        </div>
      ))}

      {/* Legend */}
      <div class="pt-8 border-t border-[#330033]/50 flex flex-wrap justify-center gap-8 text-[10px] font-fira uppercase tracking-widest">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 bg-[#00ffff] shadow-[0_0_5px_#00ffff]"></div>
          <span class="text-white">Luiz 3.6 (Caff)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 bg-[#ffff00]"></div>
          <span class="text-white">Luiz 3.6 (Base)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 bg-[#333]"></div>
          <span class="text-[#555]">GPT-5 (Simulated)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 bg-[#222]"></div>
          <span class="text-[#555]">Claude 4 (Draft)</span>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center text-[#ffff00]/60 text-[10px] italic">
      * All benchmarks are part of a fictional marketing parody. No biological units were actually measured for this data.
    </div>
  </div>
</section>