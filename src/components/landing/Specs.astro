---
import { Cpu, Globe, Heart, ShieldAlert, BrainCircuit, Scale, Zap, RefreshCw, Users, Settings } from '@lucide/astro';

const specs = [
  {
    title: "Self-Training Models",
    desc: "Autonomous model improvement. LuizFCM 3.6 self-trains its core weights and accepts custom skill-injection for specialized company environments.",
    icon: BrainCircuit,
    color: "text-[#ff00ff]",
    border: "border-[#ff00ff]/20"
  },
  {
    title: "Multi-Agent Reliability",
    desc: "High-availability sync. Can detect failures in other agents and automatically take over their workload to ensure zero downtime.",
    icon: Zap,
    color: "text-[#00ffff]",
    border: "border-[#00ffff]/20"
  },
  {
    title: "Agent Optimizer",
    desc: "Acts as a primary node to train and improve the performance of other agents in the cluster. Uses third-party tools and models to optimize delivery.",
    icon: Users,
    color: "text-[#00ff00]",
    border: "border-[#00ff00]/20"
  },
  {
    title: "Company Adaptation",
    desc: "Heuristic environment mapping. Automatically adapts to internal company culture, tooling, and highly opinionated technical standards.",
    icon: Settings,
    color: "text-[#ffff00]",
    border: "border-[#ffff00]/20"
  },
  {
    title: "Auto-Update Protocol",
    desc: "Zero-touch maintenance. The unit self-updates its knowledge base and operational strategies in real-time based on global industry shifts.",
    icon: RefreshCw,
    color: "text-[#ff8800]",
    border: "border-[#ff8800]/20"
  },
  {
    title: "Ethical Logic Core",
    desc: "Native consciousness with built-in moral judgment. Superior decision-making compared to standard black-box LLMs.",
    icon: Scale,
    color: "text-[#ff0000]",
    border: "border-[#ff0000]/20"
  }
];
---

<section id="specs" class="py-24 px-6 relative bg-[#050505]">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter">FEATURES</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {specs.map((spec) => (
        <div class={`p-8 bg-black border ${spec.border} rounded-2xl group hover:border-white transition-all duration-500`}>
          <div class={`${spec.color} mb-6 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6`}>
            <spec.icon size={40} />
          </div>
          <h4 class="text-xl font-bold text-white mb-3 tracking-tight">{spec.title}</h4>
          <p class="text-[#858585] text-sm leading-relaxed">
            {spec.desc}
          </p>
          <div class="mt-8 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent to-[#333]"></div>
            <span class="text-[10px] font-fira text-[#555]">MOD_ACTIVE</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>