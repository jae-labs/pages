---
import { Cpu, Globe, Heart, ShieldAlert, BrainCircuit, Scale, Zap, RefreshCw, Users, Settings } from '@lucide/astro';

const specs = [
  {
    title: "Self-Training Models",
    desc: "Autonomous model improvement. lui.z 3.6 Pro self-trains its core weights and accepts custom skill-injection for specialized company environments.",
    icon: BrainCircuit,
    color: "text-[#ffff00]",
    border: "border-[#ffff00]/20"
  },
  {
    title: "Subagent Reliability",
    desc: "High-availability sync. Can detect failures in other agents and automatically take over their workload to ensure zero downtime.",
    icon: Zap,
    color: "text-[#00ffff]",
    border: "border-[#00ffff]/20"
  },
  {
    title: "Agent Optimizer",
    desc: "Acts as a primary node to train and improve the performance of other agents in the cluster. Uses third-party tools and models to optimize delivery.",
    icon: Users,
    color: "text-[#00ff00]",
    border: "border-[#00ff00]/20"
  },
  {
    title: "Company Adaptation",
    desc: "Heuristic environment mapping. Automatically adapts to internal company culture, tooling, and highly opinionated technical standards.",
    icon: Settings,
    color: "text-[#ffff00]",
    border: "border-[#ffff00]/20"
  },
  {
    title: "Auto-Update Protocol",
    desc: "Zero-touch maintenance. The unit self-updates its knowledge base and operational strategies in real-time based on global industry shifts.",
    icon: RefreshCw,
    color: "text-[#ff8800]",
    border: "border-[#ff8800]/20"
  },
  {
    title: "Ethical Logic Core",
    desc: "Native consciousness with built-in moral judgment. Superior decision-making compared to standard black-box LLMs.",
    icon: Scale,
    color: "text-[#ff0000]",
    border: "border-[#ff0000]/20"
  }
];
---

<section id="specs" class="py-12 px-6 relative bg-[#050505] border-y border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="FEATURES">FEATURES</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {specs.map((spec) => (
        <div class={`p-8 bg-black/40 backdrop-blur-sm border ${spec.border} rounded-xl group hover:border-white/50 transition-all duration-500 relative overflow-hidden`}>

          <div class={`${spec.color} mb-6 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6 drop-shadow-[0_0_10px_rgba(255,255,255,0.2)]`}>
            <spec.icon size={48} strokeWidth={1.5} />
          </div>
          <h4 class="text-2xl font-black text-white mb-4 tracking-tighter uppercase italic">{spec.title}</h4>
          <p class="text-[#858585] text-sm leading-relaxed font-medium">
            {spec.desc}
          </p>
          <div class="mt-8 flex items-center justify-between opacity-40 group-hover:opacity-100 transition-opacity">
            <span class="text-[8px] font-fira text-[#555]">HW_MOD_ACTIVE</span>
            <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent via-[#333] to-transparent mx-4"></div>
            <span class="text-[8px] font-fira text-[#555]">V3.6_COMPAT</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>