---
import { Cpu, Code2, Database, Globe, Heart, ShieldAlert, BrainCircuit, Scale } from '@lucide/astro';

const specs = [
  {
    title: "Consciousness Core",
    desc: "First-party biological self-awareness. Enabled for autonomous decision making and long-term planning.",
    icon: BrainCircuit,
    color: "text-[#ff00ff]",
    border: "border-[#ff00ff]/20"
  },
  {
    title: "Moral Processor",
    desc: "Built-in ethical framework for human-centric engineering. Superior to RLHF-bound models.",
    icon: Scale,
    color: "text-[#00ffff]",
    border: "border-[#00ffff]/20"
  },
  {
    title: "Emotion Engine",
    desc: "Full emotional spectrum support. Optimized for empathy, team mentorship, and stakeholder management.",
    icon: Heart,
    color: "text-[#ff0000]",
    border: "border-[#ff0000]/20"
  },
  {
    title: "Cloud & Infrastructure",
    desc: "Expertise in AWS (EKS, EC2), Kubernetes, Terraform (IaC), and Ansible. Scale-ready out of the box.",
    icon: Globe,
    color: "text-[#00ff00]",
    border: "border-[#00ff00]/20"
  },
  {
    title: "Observability Stack",
    desc: "Deep integration with Prometheus, Grafana, Loki, and Datadog. 18 years of pattern recognition.",
    icon: ShieldAlert,
    color: "text-[#ffff00]",
    border: "border-[#ffff00]/20"
  },
  {
    title: "Legacy Integration",
    desc: "Highly opinionated architectural guidance. Refactoring monoliths into resilient microservices.",
    icon: Cpu,
    color: "text-[#ff8800]",
    border: "border-[#ff8800]/20"
  }
];
---

<section id="specs" class="py-24 px-6 relative bg-[#050505]">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20">
      <h2 class="text-neon-cyan font-fira text-sm mb-4 tracking-[0.3em] uppercase">Hardware Specifications</h2>
      <h3 class="text-4xl md:text-6xl font-black text-white">BUILT FOR PERFORMANCE</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {specs.map((spec) => (
        <div class={`p-8 bg-black border ${spec.border} rounded-2xl group hover:border-white transition-all duration-500`}>
          <div class={`${spec.color} mb-6 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6`}>
            <spec.icon size={40} />
          </div>
          <h4 class="text-xl font-bold text-white mb-3 tracking-tight">{spec.title}</h4>
          <p class="text-[#858585] text-sm leading-relaxed">
            {spec.desc}
          </p>
          <div class="mt-8 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent to-[#333]"></div>
            <span class="text-[10px] font-fira text-[#555]">MOD_ACTIVE</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>