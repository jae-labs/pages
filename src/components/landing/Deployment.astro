---

<section id="deployment" class="py-24 px-6 bg-[#050505]">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h2 class="text-[#00ff00] font-fira text-sm mb-4 tracking-[0.3em] uppercase">Audit Trail</h2>
      <h3 class="text-4xl md:text-6xl font-black text-white">DEPLOYMENT HISTORY</h3>
    </div>

    <div class="space-y-12">
      {deployments.map((d) => (
        <div class="relative pl-8 border-l border-[#330033] py-2 group hover:border-[#00ff00] transition-colors">
          {/* Timeline Dot */}
          <div class="absolute -left-1.5 top-0 w-3 h-3 bg-[#111] border border-[#330033] group-hover:border-[#00ff00] group-hover:bg-[#00ff00] rounded-full shadow-[0_0_10px_rgba(0,255,0,0)] group-hover:shadow-[0_0_10px_#00ff00] transition-all"></div>
          
          <div class="mb-4">
             <div class="flex items-center gap-3 mb-2">
                <span class="font-fira text-[9px] text-[#555]">{d.id}</span>
                <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded border ${d.status === 'CURRENT' ? 'border-[#00ff00]/30 text-[#00ff00] bg-[#00ff00]/5' : 'border-[#858585]/30 text-[#858585] bg-[#858585]/5'}`}>
                  {d.status}
                </span>
             </div>
             <h4 class="text-2xl font-black text-white group-hover:text-[#00ff00] transition-colors">{d.org}</h4>
          </div>

          <div class="space-y-4">
            {d.roles.map((r) => (
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 border-b border-white/5 pb-2 last:border-0">
                <p class="text-[#00ffff] text-sm font-medium">{r.title}</p>
                <div class="text-[9px] text-[#555] font-fira uppercase tracking-widest sm:text-right">
                  {r.date}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>