---
const deployments = [
  {
    id: "LOG_01",
    status: "CURRENT",
    org: "Prisma",
    role: "Senior Software Engineer (Infrastructure)",
    date: "Jan 2026 - Present"
  },
  {
    id: "LOG_02",
    status: "ARCHIVED",
    org: "AWS",
    role: "Senior Systems Engineer (L6)",
    date: "Jul 2025 - Oct 2025"
  },
  {
    id: "LOG_03",
    status: "ARCHIVED",
    org: "LearnUpon",
    role: "Senior Staff DevOps Engineer",
    date: "Jul 2019 - Jul 2025"
  },
  {
    id: "LOG_04",
    status: "ARCHIVED",
    org: "Griffith College Dublin",
    role: "Systems Operations Manager",
    date: "Jan 2015 - Jul 2019"
  },
  {
    id: "LOG_05",
    status: "ARCHIVED",
    org: "Ativa Investimentos",
    role: "IT Manager",
    date: "Nov 2008 - May 2014"
  },
  {
    id: "LOG_06",
    status: "ARCHIVED",
    org: "Alinfo",
    role: "Network Analyst",
    date: "Jan 2008 - Nov 2008"
  },
  {
    id: "LOG_07",
    status: "ARCHIVED",
    org: "Assessorial Ltda Epp",
    role: "Infrastructure Analyst",
    date: "Jul 2007 - Dec 2007"
  }
];
---

<section id="deployment" class="py-24 px-6 bg-[#050505]">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h2 class="text-[#00ff00] font-fira text-sm mb-4 tracking-[0.3em] uppercase">Audit Trail</h2>
      <h3 class="text-4xl md:text-6xl font-black text-white">DEPLOYMENT HISTORY</h3>
    </div>

    <div class="space-y-8">
      {deployments.map((d) => (
        <div class="relative pl-8 border-l border-[#330033] py-2 group hover:border-[#00ff00] transition-colors">
          {/* Timeline Dot */}
          <div class="absolute -left-1.5 top-1/2 -translate-y-1/2 w-3 h-3 bg-[#111] border border-[#330033] group-hover:border-[#00ff00] group-hover:bg-[#00ff00] rounded-full shadow-[0_0_10px_rgba(0,255,0,0)] group-hover:shadow-[0_0_10px_#00ff00] transition-all"></div>
          
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
            <div>
               <div class="flex items-center gap-3 mb-1">
                  <span class="font-fira text-[9px] text-[#555]">{d.id}</span>
                  <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded border ${d.status === 'CURRENT' ? 'border-[#00ff00]/30 text-[#00ff00] bg-[#00ff00]/5' : 'border-[#858585]/30 text-[#858585] bg-[#858585]/5'}`}>
                    {d.status}
                  </span>
               </div>
               <h4 class="text-xl font-bold text-white group-hover:text-[#00ff00] transition-colors">{d.org}</h4>
               <p class="text-[#00ffff] text-sm font-medium">{d.role}</p>
            </div>
            <div class="text-[10px] text-[#555] font-fira uppercase tracking-widest sm:text-right">
               {d.date}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>