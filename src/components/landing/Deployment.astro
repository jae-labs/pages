    roles: [
      { title: "Senior Systems Engineer (L6)", date: "Jul 2025 - Oct 2025" }
    ]
  },
  {
    id: "LOG_03",
    status: "ARCHIVED",
    org: "LearnUpon",
    roles: [
      { title: "Senior Staff DevOps Engineer", date: "Apr 2025 – Jul 2025" },
      { title: "Staff DevOps Engineer", date: "Feb 2023 – Apr 2025" },
      { title: "Senior DevOps Engineer", date: "Jul 2021 – Feb 2023" },
      { title: "DevOps Engineer", date: "Jun 2020 – Jul 2021" },
      { title: "Site Reliability Engineer", date: "Jul 2019 – Jun 2020" }
    ]
  },
  {
    id: "LOG_04",
    status: "ARCHIVED",
    org: "Griffith College Dublin",
    roles: [
      { title: "Systems Operations Manager", date: "Mar 2019 – Jul 2019" },
      { title: "Senior Systems & Network Administrator", date: "Jan 2015 – Mar 2019" }
    ]
  },
  {
    id: "LOG_05",
    status: "ARCHIVED",
    org: "Ativa Investimentos",
    roles: [
      { title: "IT Manager", date: "Aug 2013 – May 2014" },
      { title: "Network Team Leader", date: "Sep 2012 – Aug 2013" },
      { title: "Senior Network Engineer", date: "Oct 2009 – Sep 2012" },
      { title: "Network Analyst Intern", date: "Nov 2008 – Oct 2009" }
    ]
  },
  {
    id: "LOG_06",
    status: "ARCHIVED",
    org: "Alinfo",
    roles: [
      { title: "Network Analyst", date: "Jan 2008 – Nov 2008" }
    ]
  },
  {
