<section id="deployment" class="py-24 px-6 bg-[#050505]">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-cyan"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="CHANGELOG">CHANGELOG</h3>
    </div>

    <div class="space-y-16">
      {deployments.map((d) => (
        <div class="relative group border border-white/5 bg-[#050505]/40 backdrop-blur-sm p-8 rounded-2xl overflow-hidden">
          <div class="hud-corner-tl !w-2 !h-2"></div>
          <div class="hud-corner-br !w-2 !h-2"></div>
          
          <div class="mb-8 border-b border-white/10 pb-4 relative">
             <div class="flex items-center gap-4 mb-4">
                <span class="text-[10px] font-fira text-[#ff00ff] border border-[#ff00ff]/30 px-2 py-0.5 rounded bg-[#ff00ff]/5 uppercase font-bold">
                   Release {d.id}
                </span>
                <span class="text-[10px] font-fira text-[#00ffff] border border-[#00ffff]/30 px-2 py-0.5 rounded bg-[#00ffff]/5 uppercase">
                   Region: {d.region}
                </span>
                <span class={`text-[10px] font-fira px-2 py-0.5 rounded border ${d.status === 'CURRENT' ? 'border-[#00ff00]/30 text-[#00ff00] bg-[#00ff00]/5' : 'border-[#858585]/30 text-[#858585] bg-[#858585]/5'} uppercase font-bold`}>
                  {d.status}
                </span>
             </div>
             <h4 class="text-4xl font-black text-white uppercase tracking-tighter group-hover:text-neon-pink transition-colors">
                ## {d.org}
             </h4>
          </div>

          <div class="space-y-12 pl-4">
            {d.roles.map((r) => (
              <div class="relative font-fira">
                <div class="flex items-center gap-4 mb-4">
                   <span class="text-lg font-black text-[#ff00ff]">{r.version}</span>
                   <div class="h-[1px] flex-1 bg-white/5"></div>
                   <span class="text-[10px] text-[#555] uppercase tracking-[0.2em]">{r.date}</span>
                </div>
                
                <div class="bg-[#0a0a0a] border border-white/5 rounded-lg p-6 group-hover:border-[#ff00ff]/20 transition-all shadow-inner">
                   <p class="text-[#00ffff] font-black text-sm mb-4 uppercase tracking-wide">
                      ### {r.title}
                   </p>
                   
                   <div class="space-y-2 text-xs leading-relaxed text-[#858585]">
                      <div class="flex gap-3">
                         <span class="text-[#ff00ff] shrink-0">•</span>
                         <span>{r.summary}</span>
                      </div>
                   </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>