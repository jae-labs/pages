    roles: [
      { title: "Systems Operations Manager", date: "Mar 2019 – Jul 2019" },
      { title: "Senior Systems & Network Administrator", date: "Jan 2015 – Mar 2019" }
    ]
  },
  {
    id: "LOG_05",
    status: "ARCHIVED",
    org: "Ativa Investimentos",
    summary: "Managed ultra-low-latency financial infrastructure and led zero-downtime datacenter migrations.",
    roles: [
      { title: "IT Manager", date: "Aug 2013 – May 2014" },
      { title: "Network Team Leader", date: "Sep 2012 – Aug 2013" },
      { title: "Senior Network Engineer", date: "Oct 2009 – Sep 2012" },
      { title: "Network Analyst Intern", date: "Nov 2008 – Oct 2009" }
    ]
  },
  {
    id: "LOG_06",
    status: "ARCHIVED",
