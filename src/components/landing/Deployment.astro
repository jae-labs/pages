---
const deployments = [
  {
    id: "LOG_01",
    status: "CURRENT",
    org: "Prisma",
    role: "Senior Software Engineer (Infrastructure)",
    date: "2026 - Present",
    logs: [
      "Built AI-assisted Grafana development stack.",
      "Eliminated 95% manual provisioning via autonomous agents.",
      "Achieved 0 secret leak incidents via SAST automation."
    ]
  },
  {
    id: "LOG_02",
    status: "ARCHIVED",
    org: "AWS",
    role: "Senior Systems Engineer (L6)",
    date: "2025 - 2025",
    logs: [
      "Visualized large-scale project deliverables for EUSC regions.",
      "Reduced manual effort by >90% via automated refreshing.",
      "Streamlined bulk task management from hours to minutes."
    ]
  },
  {
    id: "LOG_03",
    status: "ARCHIVED",
    org: "LearnUpon",
    role: "Senior Staff DevOps Engineer",
    date: "2019 - 2025",
    logs: [
      "Architected AWS (EKS) infrastructure with 99.99% uptime.",
      "Reduced MTTR by 60% via advanced monitoring (Prometheus/Loki).",
      "Cut deployment time by 70% using GitLab CI and Terraform."
    ]
  }
];
---

<section id="deployment" class="py-24 px-6 bg-[#050505]">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h2 class="text-[#00ff00] font-fira text-sm mb-4 tracking-[0.3em] uppercase">Audit Trail</h2>
      <h3 class="text-4xl md:text-6xl font-black text-white">DEPLOYMENT HISTORY</h3>
    </div>

    <div class="space-y-12">
      {deployments.map((d) => (
        <div class="relative pl-8 border-l border-[#330033]">
          {/* Timeline Dot */}
          <div class="absolute -left-1.5 top-0 w-3 h-3 bg-[#00ff00] rounded-full shadow-[0_0_10px_#00ff00]"></div>
          
          <div class="flex items-center gap-4 mb-4">
            <span class="font-fira text-[10px] text-[#555]">{d.id}</span>
            <span class={`text-[10px] font-bold px-2 py-0.5 rounded border ${d.status === 'COMPLETED' ? 'border-[#00ff00]/30 text-[#00ff00] bg-[#00ff00]/5' : 'border-[#858585]/30 text-[#858585] bg-[#858585]/5'}`}>
              {d.status}
            </span>
            <span class="text-[10px] text-[#555] font-fira">{d.date}</span>
          </div>

          <h4 class="text-2xl font-bold text-white mb-1">{d.org}</h4>
          <p class="text-[#00ffff] font-medium mb-6">{d.role}</p>
          
          <div class="bg-black/50 border border-[#330033]/50 rounded-xl p-6 font-fira text-xs">
            {d.logs.map((log) => (
              <div class="flex gap-4 mb-2">
                <span class="text-[#555] shrink-0">[INIT]</span>
                <span class="text-[#858585]">{log}</span>
              </div>
            ))}
            <div class="mt-4 flex gap-4">
              <span class="text-[#00ff00] shrink-0">[DONE]</span>
              <span class="text-[#e0e0e0]">Block successfully merged.</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>