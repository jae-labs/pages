---
const tiers = [
  {
    name: "Community",
    price: "$0",
    desc: "Pro-bono integration for non-profits, charities, and open-source contributions.",
    features: ["Full human agent capability", "Self-hosted in eu-west-1", "Subject to bio-unit availability"],
    cta: "Contact Us",
    color: "border-[#00ff00]/30",
    tenancy: "Shared Tenancy",
    tenancyColor: "bg-[#00ff00] text-black"
  },
  {
    name: "Enterprise",
    price: "Contact Us",
    desc: "Single-tenant provisioning for high-scale, mission-critical environments.",
    features: ["Flexible pricing", "Dedicated processing power", "Subagent failover sync", "Custom skill injection", "Reduced cancellation fee during probation", "ON-CALL [PREMIUM DLC]", "Direct API access"],
    cta: "Contact Us",
    color: "border-neon-yellow",
    popular: true,
    urgency: "ONLY 1 LICENSE LEFT",
    tenancy: "Single Tenant",
    tenancyColor: "bg-neon-yellow text-black"
  }
];
---

<section id="pricing" class="py-12 px-6 relative overflow-hidden border-y border-white/5 bg-black">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 relative">
      <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-1 h-12 bg-neon-yellow"></div>
      <h3 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter glitch" data-text="PLANS">PLANS</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
      {tiers.map((t) => (
        <div class={`relative p-8 rounded-3xl border ${t.color} bg-black flex flex-col transition-transform hover:-translate-y-2 duration-500`}>
          {t.tenancy && (
            <div class={`absolute -top-4 left-1/2 -translate-x-1/2 ${t.tenancyColor} text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full shadow-[0_0_20px_rgba(255,255,255,0.1)]`}>
              {t.tenancy}
            </div>
          )}

          <div class="h-6 mb-4">
            {t.urgency && (
              <div class="flex items-center gap-2">
                <span class="flex h-2 w-2 rounded-full bg-[#ff0000] animate-pulse shadow-[0_0_8px_#ff0000]"></span>
                <span class="text-[10px] font-black text-[#ff0000] tracking-widest animate-pulse">
                  {t.urgency}
                </span>
              </div>
            )}
          </div>
          
          <div class="mb-8">
            <h4 class="text-2xl font-black text-white mb-2">{t.name}</h4>
            <div class="text-4xl font-black text-white mb-4 italic">{t.price}</div>
            <p class="text-[#858585] text-sm leading-relaxed">{t.desc}</p>
          </div>

          <ul class="space-y-4 mb-12 flex-1">
            {t.features.map((f) => (
              <li class="flex items-center gap-3 text-sm text-[#e0e0e0]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ffff00] shadow-[0_0_5px_#ffff00]"></div>
                {f}
              </li>
            ))}
          </ul>

          <a href="mailto:luiz@justanother.engineer" class={`w-full py-4 rounded-xl font-black uppercase tracking-widest text-center transition-all ${t.popular ? 'bg-neon-yellow text-black hover:shadow-[0_0_30px_#ffff00]' : 'border border-[#330033] text-white hover:bg-white/5'}`}>
            {t.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>