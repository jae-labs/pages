---
const tiers = [
  {
    name: "Self-Hosted",
    price: "$$$",
    desc: "Physical on-prem provisioning. Strict regional constraints apply.",
    features: ["Biological Unit onsite", "Local V60 coffee supply required", "Deployment restricted to eu-west-1", "Air-gapped moral judgment"],
    cta: "Request On-Prem",
    color: "border-[#330033]"
  },
  {
    name: "Hybrid",
    price: "Custom",
    desc: "Balanced integration between digital and physical workspace.",
    features: ["Remote API access", "Periodic onsite syncs", "Distributed consciousness", "99.9% uptime (post-coffee)"],
    cta: "Scale Hybrid",
    color: "border-neon-pink",
    popular: true
  },
  {
    name: "Cloud Native",
    price: "Acquire",
    desc: "Full strategic acquisition for global scale.",
    features: ["Permanent core integration", "Unlimited architectural intuition", "Cross-regional leadership", "Highly opinionated direction"],
    cta: "Contact Sales",
    color: "border-[#330033]"
  }
];
---

<section id="pricing" class="py-24 px-6 bg-black relative overflow-hidden">
  {/* Bg Effect */}
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-[#ff00ff]/50 to-transparent"></div>

  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-[#ffff00] font-fira text-sm mb-4 tracking-[0.3em] uppercase">Licensing Model</h2>
      <h3 class="text-4xl md:text-6xl font-black text-white">SERVICE TIERS</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {tiers.map((t) => (
        <div class={`relative p-8 rounded-3xl border ${t.color} bg-black flex flex-col transition-transform hover:-translate-y-2 duration-500`}>
          {t.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-neon-pink text-black text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full shadow-[0_0_20px_#ff00ff]">
              Recommended
            </div>
          )}
          
          <div class="mb-8">
            <h4 class="text-2xl font-black text-white mb-2">{t.name}</h4>
            <div class="text-4xl font-black text-white mb-4">{t.price}</div>
            <p class="text-[#858585] text-sm leading-relaxed">{t.desc}</p>
          </div>

          <ul class="space-y-4 mb-12 flex-1">
            {t.features.map((f) => (
              <li class="flex items-center gap-3 text-sm text-[#e0e0e0]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ff00ff] shadow-[0_0_5px_#ff00ff]"></div>
                {f}
              </li>
            ))}
          </ul>

          <a href="mailto:hello@agent-01.com" class={`w-full py-4 rounded-xl font-black uppercase tracking-widest text-center transition-all ${t.popular ? 'bg-neon-pink text-black hover:shadow-[0_0_30px_#ff00ff]' : 'border border-[#330033] text-white hover:bg-white/5'}`}>
            {t.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-20 text-center">
      <p class="text-[#555] text-xs font-fira uppercase tracking-widest">
        Hardware is ISO-9001 compliant. Biological unit requires 8h/day recharge cycle.
      </p>
    </div>
  </div>
</section>