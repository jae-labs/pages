---
const tiers = [
  {
    name: "Community",
    price: "$0",
    desc: "Pro-bono integration for non-profits, charities, and open-source contributions.",
    features: ["Volunteer-first priority", "Full AGI capability", "Self-hosted in eu-west-1", "Subject to bio-unit availability"],
    cta: "Contact Us",
    color: "border-[#00ff00]/30"
  },
  {
    name: "Enterprise",
    price: "Contact Us",
    desc: "Single-tenant provisioning for high-scale, mission-critical environments.",
    features: ["Dedicated processing power", "Multi-agent failover sync", "Custom skill injection", "Full GDPR compliance", "Direct API access (Email)"],
    cta: "Contact Us",
    color: "border-neon-pink",
    popular: true,
    urgency: "ONLY 1 LICENSE LEFT"
  }
];
---

<section id="pricing" class="py-24 px-6 bg-black relative overflow-hidden text-center">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20">
      <h2 class="text-[#ffff00] font-fira text-sm mb-4 tracking-[0.3em] uppercase">Licensing Model</h2>
      <h3 class="text-4xl md:text-6xl font-black text-white italic">SERVICE TIERS</h3>
      <p class="mt-6 text-[#858585] max-w-2xl mx-auto">LuizFCM 3.6 follows a strict single-tenant model. Biological hardware constraints apply.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto text-left">
      {tiers.map((t) => (
        <div class={`relative p-8 rounded-3xl border ${t.color} bg-black flex flex-col transition-transform hover:-translate-y-2 duration-500`}>
          {t.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-neon-pink text-black text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full shadow-[0_0_20px_#ff00ff]">
              Single Tenant
            </div>
          )}

          {t.urgency && (
            <div class="mb-4 flex items-center gap-2">
              <span class="flex h-2 w-2 rounded-full bg-[#ff0000] animate-pulse shadow-[0_0_8px_#ff0000]"></span>
              <span class="text-[10px] font-black text-[#ff0000] tracking-widest animate-pulse">
                {t.urgency} — RUNNING OUT
              </span>
            </div>
          )}
          
          <div class="mb-8">
            <h4 class="text-2xl font-black text-white mb-2">{t.name}</h4>
            <div class="text-4xl font-black text-white mb-4 italic">{t.price}</div>
            <p class="text-[#858585] text-sm leading-relaxed">{t.desc}</p>
          </div>

          <ul class="space-y-4 mb-12 flex-1">
            {t.features.map((f) => (
              <li class="flex items-center gap-3 text-sm text-[#e0e0e0]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ff00ff] shadow-[0_0_5px_#ff00ff]"></div>
                {f}
              </li>
            ))}
          </ul>

          <a href="mailto:hello@luizfcm.com" class={`w-full py-4 rounded-xl font-black uppercase tracking-widest text-center transition-all ${t.popular ? 'bg-neon-pink text-black hover:shadow-[0_0_30px_#ff00ff]' : 'border border-[#330033] text-white hover:bg-white/5'}`}>
            {t.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-20 max-w-2xl mx-auto text-[10px] font-fira text-[#555] uppercase tracking-widest leading-relaxed">
      <p class="mb-4">Trial period available with reduced cancellation fees for the first 6 months. After 12 months, all statutory changes and adjustments apply automatically.</p>
      <p>LuizFCM 3.6 is fully <span class="text-white">GDPR Compliant</span>. Bio-unit data remains isolated in the host region.</p>
    </div>
  </div>
</section>