---
import { Share2, ZapOff, ShieldCheck, Users } from '@lucide/astro';
---

<section id="reliability" class="py-24 px-6 relative bg-black overflow-hidden">
  {/* Decorative grid background */}
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-neon-cyan font-fira text-sm mb-4 tracking-[0.3em] uppercase">Redundancy Protocol</h2>
        <h3 class="text-4xl md:text-6xl font-black text-white mb-8">MULTI-AGENT MESH ARCHITECTURE</h3>
        
        <div class="space-y-8 text-[#858585] leading-relaxed">
          <p class="text-lg">
            LuizFCM 3.6 isn't just a single unit; it's a <span class="text-white">High-Availability Node</span> designed to integrate into your existing human and synthetic agent clusters.
          </p>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#00ffff]/10 flex items-center justify-center text-[#00ffff]">
                <Share2 size={24} />
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Dynamic Workload Balancing</h4>
                <p class="text-sm">Automatically splits complex engineering blocks with peers. Parallel processing enabled by default across bio-neural networks.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#ff00ff]/10 flex items-center justify-center text-[#ff00ff]">
                <ZapOff size={24} />
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Failover & Takeover</h4>
                <p class="text-sm">In the event of a peer agent outage (sleep, vacation, or hardware failure), LuizFCM 3.6 initiates an <span class="text-[#ff00ff]">Emergency Takeover Protocol</span>, absorbing and routing the failed unit's workload.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#00ff00]/10 flex items-center justify-center text-[#00ff00]">
                <Users size={24} />
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Biological Consensus</h4>
                <p class="text-sm">Syncs with other human agents to maintain architectural consistency. Prevents technical debt drift through peer-to-peer code-level negotiation.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="bg-black border border-[#330033] rounded-3xl p-8 relative overflow-hidden shadow-[0_0_50px_rgba(255,0,255,0.1)]">
          {/* Visual representation of the Mesh with Luiz & Bob Failover Animation */}
          <div class="relative aspect-square flex items-center justify-center">
             
             {/* The Project Node (Central) */}
             <div class="absolute z-10 w-24 h-24 rounded-2xl border-2 border-white/20 bg-black/40 backdrop-blur-md flex items-center justify-center group overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-[#ff00ff]/10 to-[#00ffff]/10 animate-pulse"></div>
                <div class="relative flex flex-col items-center">
                   <ShieldCheck size={32} class="text-white mb-1 animate-bounce" />
                   <span class="text-[8px] font-black text-white tracking-widest uppercase text-center">PROJECT<br/>ONE</span>
                </div>
                {/* Progress Bar in Project */}
                <div class="absolute bottom-0 left-0 h-1 bg-gradient-to-r from-[#ff00ff] to-[#00ffff] animate-project-progress"></div>
             </div>

             {/* Luiz Node */}
             <div class="absolute top-1/2 left-1/2 -translate-x-[140px] -translate-y-1/2 flex flex-col items-center animate-failover-luiz">
                <div class="w-20 h-20 rounded-full p-1 border-2 border-current bg-black relative">
                   <img src="/agent.png" class="w-full h-full rounded-full object-cover grayscale brightness-75 contrast-125 animate-failover-image" />
                   <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black border border-current px-2 py-0.5 rounded text-[6px] font-black whitespace-nowrap">
                      LUIZ_AGI_3.6
                   </div>
                </div>
                {/* Data Flow Line to Project - Arrows both ways */}
                <div class="w-16 h-1 flex items-center justify-between absolute top-1/2 left-full -translate-y-1/2 animate-failover-flow-left">
                   <div class="w-1.5 h-1.5 border-t border-l border-current rotate-[-45deg]"></div>
                   <div class="h-[1px] flex-1 bg-current mx-1"></div>
                   <div class="w-1.5 h-1.5 border-t border-r border-current rotate-[45deg]"></div>
                </div>
             </div>

             {/* Bob Node (Peer Agent) */}
             <div class="absolute top-1/2 left-1/2 translate-x-[60px] -translate-y-1/2 flex flex-col items-center">
                <div class="w-20 h-20 rounded-full p-1 border-2 border-[#00ffff] bg-black relative animate-failover-bob">
                   <div class="w-full h-full rounded-full bg-[#111] flex items-center justify-center text-[#00ffff]">
                      <Users size={32} />
                   </div>
                   <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black border border-[#00ffff] px-2 py-0.5 rounded text-[6px] font-black text-[#00ffff] whitespace-nowrap uppercase">
                      Bob_Peer_Agent
                   </div>
                </div>
                {/* Data Flow Line to Project - Arrows both ways */}
                <div class="w-16 h-1 flex items-center justify-between absolute top-1/2 right-full -translate-y-1/2 animate-failover-flow-right">
                   <div class="w-1.5 h-1.5 border-t border-l border-[#00ffff] rotate-[-45deg]"></div>
                   <div class="h-[1px] flex-1 bg-[#00ffff] mx-1"></div>
                   <div class="w-1.5 h-1.5 border-t border-r border-[#00ffff] rotate-[45deg]"></div>
                </div>
             </div>
          </div>

          {/* Failover Logs */}
          <div class="mt-8 bg-black border border-white/10 rounded-xl p-4 font-fira text-[10px] overflow-hidden h-32 relative">
             <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/80 pointer-events-none z-10"></div>
             <div class="space-y-1 animate-failover-logs text-[#858585]">
                <p class="text-[#00ff00] uppercase">[OK] LUIZ & BOB COLLABORATING ON PROJECT ONE</p>
                <p class="text-[#ff00ff] uppercase">[LUIZ] SYNCING_PROJECT_STATE...</p>
                <p class="text-[#00ffff] uppercase">[BOB] FETCHING_LATEST_COMMITS...</p>
                <p class="text-[#ff0000] font-black animate-pulse uppercase">!! [ALERT] LUIZ_AGI_3.6 DISCONNECTED !!</p>
                <p class="text-[#00ffff] uppercase">[FAILOVER] BOB_AGENT TAKING OVER LUIZ_PIPELINE</p>
                <p class="text-[#00ffff] uppercase">[SUCCESS] PROJECT ONE PRODUCTION UNINTERRUPTED</p>
                <p class="text-[#00ff00] uppercase">[OK] LUIZ_AGI_3.6 RECONNECTED</p>
                <p class="uppercase">[INFO] BI-DIRECTIONAL SYNC RESTORED...</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes failover-luiz {
    0%, 30% { color: #ff00ff; opacity: 1; transform: translateX(-140px) translateY(-50%) scale(1); }
    35%, 65% { color: #ff0000; opacity: 0.5; transform: translateX(-140px) translateY(-50%) scale(0.9); }
    70%, 100% { color: #ff00ff; opacity: 1; transform: translateX(-140px) translateY(-50%) scale(1); }
  }

  @keyframes failover-bob {
    0%, 30% { transform: scale(1); border-color: #00ffff; box-shadow: none; }
    35%, 65% { transform: scale(1.1); border-color: #00ffff; box-shadow: 0 0 20px #00ffff55; }
    70%, 100% { transform: scale(1); border-color: #00ffff; box-shadow: none; }
  }

  @keyframes failover-image {
    0%, 30% { filter: grayscale(1) brightness(0.75); }
    35%, 65% { filter: grayscale(1) brightness(0.1); }
    70%, 100% { filter: grayscale(1) brightness(0.75); }
  }

  @keyframes failover-flow-left {
    0%, 30% { opacity: 1; width: 60px; }
    35%, 65% { opacity: 0; width: 0; }
    70%, 100% { opacity: 1; width: 60px; }
  }

  @keyframes failover-flow-right {
    0%, 30% { opacity: 1; width: 60px; }
    35%, 65% { opacity: 1; width: 140px; transform: translateX(-140px) translateY(-50%); }
    70%, 100% { opacity: 1; width: 60px; transform: translateX(0) translateY(-50%); }
  }

  @keyframes project-progress {
    0% { width: 0%; }
    100% { width: 100%; }
  }

  @keyframes failover-logs {
    0% { transform: translateY(0); }
    30% { transform: translateY(-20px); }
    40% { transform: translateY(-60px); }
    60% { transform: translateY(-100px); }
    70% { transform: translateY(-140px); }
    100% { transform: translateY(0); }
  }

  .animate-failover-luiz { animation: failover-luiz 10s infinite; }
  .animate-failover-bob { animation: failover-bob 10s infinite; }
  .animate-failover-image { animation: failover-image 10s infinite; }
  .animate-failover-flow-left { animation: failover-flow-left 10s infinite; }
  .animate-failover-flow-right { animation: failover-flow-right 10s infinite; }
  .animate-project-progress { animation: project-progress 5s linear infinite; }
  .animate-failover-logs { animation: failover-logs 10s infinite; }
</style>