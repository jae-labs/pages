---
import { Share2, ZapOff, ShieldCheck, Users } from '@lucide/astro';
---

<section id="reliability" class="py-24 px-6 relative bg-black overflow-hidden">
  {/* Decorative grid background */}
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-neon-cyan font-fira text-sm mb-4 tracking-[0.3em] uppercase">Redundancy Protocol</h2>
        <h3 class="text-4xl md:text-6xl font-black text-white mb-8">MULTI-AGENT MESH ARCHITECTURE</h3>
        
        <div class="space-y-8 text-[#858585] leading-relaxed">
          <p class="text-lg">
            LuizFCM 3.6 isn't just a single unit; it's a <span class="text-white">High-Availability Node</span> designed to integrate into your existing human and synthetic agent clusters.
          </p>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#00ffff]/10 flex items-center justify-center text-[#00ffff]">
                <Share2 size={24} />
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Dynamic Workload Balancing</h4>
                <p class="text-sm">Automatically splits complex engineering blocks with peers. Parallel processing enabled by default across bio-neural networks.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#ff00ff]/10 flex items-center justify-center text-[#ff00ff]">
                <ZapOff size={24} />
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Failover & Takeover</h4>
                <p class="text-sm">In the event of a peer agent outage (sleep, vacation, or hardware failure), LuizFCM 3.6 initiates an <span class="text-[#ff00ff]">Emergency Takeover Protocol</span>, absorbing and routing the failed unit's workload.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#00ff00]/10 flex items-center justify-center text-[#00ff00]">
                <Users size={24} />
              </div>
              <div>
                <h4 class="text-white font-bold mb-1">Biological Consensus</h4>
                <p class="text-sm">Syncs with other human agents to maintain architectural consistency. Prevents technical debt drift through peer-to-peer code-level negotiation.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="bg-black border border-[#330033] rounded-3xl p-8 relative overflow-hidden shadow-[0_0_50px_rgba(255,0,255,0.1)]">
          {/* Visual representation of the Mesh */}
          <div class="relative aspect-square flex items-center justify-center">
             {/* Central Node (Luiz) */}
             <div class="relative z-20 w-32 h-32 rounded-full border-2 border-[#ff00ff] p-1 animate-pulse">
                <img src="/agent.png" class="w-full h-full rounded-full object-cover grayscale brightness-75 contrast-125" />
             </div>

             {/* Orbital Nodes (Peers) */}
             <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-full h-full border border-dashed border-[#330033] rounded-full animate-[spin_20s_linear_infinite]"></div>
                
                {/* Node 1 - Active */}
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
                  <div class="w-12 h-12 bg-[#111] border border-[#00ffff] rounded-full flex items-center justify-center text-[#00ffff] shadow-[0_0_10px_#00ffff]">
                    <ShieldCheck size={20} />
                  </div>
                  <span class="text-[8px] font-fira text-[#00ffff] mt-2">PEER_ACTIVE</span>
                </div>

                {/* Node 2 - Failed/Offline */}
                <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 flex flex-col items-center">
                  <div class="w-12 h-12 bg-black border border-red-900 rounded-full flex items-center justify-center text-red-900 group">
                    <ZapOff size={20} />
                    {/* Redirecting Arrow */}
                    <div class="absolute -top-12 left-0 w-1 h-12 bg-gradient-to-b from-[#ff00ff] to-transparent"></div>
                  </div>
                  <span class="text-[8px] font-fira text-red-900 mt-2">NODE_FAILURE</span>
                </div>

                {/* Node 3 - Syncing */}
                <div class="absolute left-0 top-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
                  <div class="w-12 h-12 bg-[#111] border border-[#330033] rounded-full flex items-center justify-center text-[#330033]">
                    <Users size={20} />
                  </div>
                  <span class="text-[8px] font-fira text-[#330033] mt-2">SYNC_IN_PROGRESS</span>
                </div>
             </div>

             {/* Connectivity lines/pulses */}
             <div class="absolute inset-0 flex items-center justify-center">
               <div class="w-48 h-48 border border-[#ff00ff]/20 rounded-full animate-ping"></div>
             </div>
          </div>

          <div class="mt-8 bg-white/5 border border-white/10 rounded-xl p-4 font-fira text-[10px] text-white/50">
             <div class="flex justify-between mb-2">
               <span>MESS_STABILITY</span>
               <span class="text-[#00ff00]">OPTIMAL</span>
             </div>
             <div class="w-full h-1 bg-white/10 rounded-full overflow-hidden">
               <div class="w-[99%] h-full bg-[#00ff00] shadow-[0_0_10px_#00ff00]"></div>
             </div>
             <p class="mt-4 text-[#858585]">LuizFCM 3.6 is currently absorbing data from 2 redundant peer clusters. Zero loss detected.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>