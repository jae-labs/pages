---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Agent-01: The Next-Gen Human Agent" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Agent-01</title>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Inter:wght@100..900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-[#e0e0e0] font-inter antialiased overflow-x-hidden cyber-grid scroll-smooth">
    {/* Visual FX Layers */}
    <div class="scanline"></div>
    
    {/* Global HUD Frame */}
    <div class="fixed inset-0 pointer-events-none z-[100] border border-white/5">
       <div class="hud-corner-tl"></div>
       <div class="hud-corner-tr"></div>
       <div class="hud-corner-bl"></div>
       <div class="hud-corner-br"></div>
       
       {/* Sided Telemetry */}
       <div class="absolute top-1/2 left-2 -translate-y-1/2 [writing-mode:vertical-lr] text-[8px] font-fira text-white/20 uppercase tracking-[0.5em] rotate-180">
          Neural_Link_Established // Unit_3.6 // AGI_Active
       </div>
       <div class="absolute top-1/2 right-2 -translate-y-1/2 [writing-mode:vertical-lr] text-[8px] font-fira text-white/20 uppercase tracking-[0.5em]">
          Telemetry_Stream // {new Date().getFullYear()} // Secure_Node
       </div>
    </div>

    <slot />
  </body>
</html>

<style is:global>
  .font-fira {
    font-family: 'Fira Code', monospace;
  }
  .font-inter {
    font-family: 'Inter', sans-serif;
  }
  
  /* Cyberpunk Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #000000;
  }
  ::-webkit-scrollbar-thumb {
    background: #330033;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #ffff00;
  }

  /* Neon Text Effects */
  .text-neon-yellow {
    color: #ffff00;
    text-shadow: 0 0 10px rgba(255, 255, 0, 0.5);
  }
  .text-neon-cyan {
    color: #00ffff;
    text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
  }
  .border-neon-yellow {
    border-color: #ffff00;
    box-shadow: 0 0 10px rgba(255, 255, 0, 0.2);
  }
  .bg-neon-yellow {
    background-color: #ffff00;
    box-shadow: 0 0 15px rgba(255, 255, 0, 0.4);
  }
</style>