---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  socialImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'lui.z: cyberpunk-styled human agent portfolio focused on SRE, DevOps, platform engineering, and reliability.',
  socialImage = '/agent-hover.png',
  noindex = false
} = Astro.props;
const pageTitle = title;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const socialImageURL = /^(https?:)?\/\//.test(socialImage)
  ? socialImage
  : new URL(socialImage, Astro.site ?? Astro.url).toString();
const websiteURL = Astro.site ? new URL(import.meta.env.BASE_URL, Astro.site).toString() : canonicalURL;
const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'lui.z',
  url: websiteURL,
  description,
  inLanguage: 'en'
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Luiz F. C. Martins" />
    <meta name="theme-color" content="#050505" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="lui.z" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="bg-black text-[#e0e0e0] font-inter antialiased overflow-x-hidden cyber-grid scroll-smooth">
    {/* Visual FX Layers */}
    <div class="scanline"></div>
    
    {/* Global HUD Frame */}
    <div class="fixed inset-0 pointer-events-none z-[100] border border-white/5">
       
    </div>

    <slot />

    <div id="cookie-banner" class="hidden fixed bottom-4 left-4 right-4 z-[950]">
      <div class="mx-auto max-w-4xl border border-neon-yellow/40 bg-black/95 backdrop-blur-xl rounded-2xl p-4 sm:p-5 shadow-[0_0_30px_rgba(255,140,0,0.2)]">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-[10px] uppercase tracking-[0.2em] text-neon-yellow font-black mb-1">Notice</p>
            <p class="text-sm text-[#bfbfbf] leading-relaxed">
              This website uses cookies and advanced analytics (Google Analytics & PostHog) to optimize performance, capture heatmaps, and record sessions. We require your consent before loading non-essential cookies.
            </p>
          </div>
          <div class="flex gap-3 shrink-0">
            <button id="cookie-decline" type="button" class="px-4 py-2 border border-[#bfbfbf]/30 hover:border-red-500/50 hover:text-red-500/80 rounded-lg text-xs font-black uppercase tracking-widest text-[#bfbfbf] transition-all">
              Decline
            </button>
            <button id="cookie-accept" type="button" class="px-4 py-2 bg-neon-yellow text-black rounded-lg text-xs font-black uppercase tracking-widest hover:brightness-110 shadow-[0_0_15px_rgba(243,235,44,0.3)] transition-all">
              Accept
            </button>
          </div>
        </div>
      </div>
    </div>

    <script>
      import posthog from 'posthog-js';

      const GA_TRACKING_ID = import.meta.env.PUBLIC_GA_TRACKING_ID || 'G-N556PF9XWK';
      const COOKIE_CONSENT_KEY = 'cookie-consent';
      const ACCEPTED = 'accepted';
      const REJECTED = 'rejected';
      const PH_KEY = import.meta.env.PUBLIC_POSTHOG_KEY;
      const PH_HOST = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://eu.i.posthog.com';

      type AnalyticsWindow = Window & typeof globalThis & {
        __gaInitialized?: boolean;
        __posthog_initialized?: boolean;
        dataLayer?: unknown[][];
        gtag?: (...args: unknown[]) => void;
      };

      const analyticsWindow = window as AnalyticsWindow;

      const loadAnalytics = () => {
        if (analyticsWindow.__gaInitialized) return;
        analyticsWindow.__gaInitialized = true;

        analyticsWindow.dataLayer = analyticsWindow.dataLayer || [];
        analyticsWindow.gtag = (...args: unknown[]) => {
          analyticsWindow.dataLayer?.push(args);
        };

        const script = document.createElement('script');
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_TRACKING_ID}`;
        document.head.appendChild(script);

        analyticsWindow.gtag('js', new Date());
        analyticsWindow.gtag('config', GA_TRACKING_ID, { anonymize_ip: true });
      };

      const loadPostHog = () => {
        if (PH_KEY && !analyticsWindow.__posthog_initialized) {
          analyticsWindow.__posthog_initialized = true;
          posthog.init(PH_KEY, {
            api_host: PH_HOST,
            capture_pageview: 'history_change',
            persistence: 'localStorage',
            autocapture: true,
            session_recording: {
              maskAllInputs: true,
            }
          });
        }
      };

      const initCookieBanner = () => {
        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('cookie-accept');
        const declineBtn = document.getElementById('cookie-decline');
        if (!banner || !acceptBtn || !declineBtn) return;

        const consent = localStorage.getItem(COOKIE_CONSENT_KEY);
        if (consent === ACCEPTED) {
          loadAnalytics();
          loadPostHog();
          banner.classList.add('hidden');
          return;
        } else if (consent === REJECTED) {
          banner.classList.add('hidden');
          return;
        }

        banner.classList.remove('hidden');

        if (!acceptBtn.dataset.bound) {
          acceptBtn.addEventListener('click', () => {
            localStorage.setItem(COOKIE_CONSENT_KEY, ACCEPTED);
            loadAnalytics();
            loadPostHog();
            banner.classList.add('hidden');
          });
          acceptBtn.dataset.bound = 'true';
        }

        if (!declineBtn.dataset.bound) {
          declineBtn.addEventListener('click', () => {
            localStorage.setItem(COOKIE_CONSENT_KEY, REJECTED);
            banner.classList.add('hidden');
          });
          declineBtn.dataset.bound = 'true';
        }
      };

      if (document.readyState !== 'loading') {
        initCookieBanner();
      } else {
        document.addEventListener('DOMContentLoaded', initCookieBanner, { once: true });
      }

      document.addEventListener('astro:page-load', () => {
        initCookieBanner();
      });
    </script>
    <script>
      import posthog from 'posthog-js';

      let calendlyLoading = false;
      type CalendlyWindow = Window & typeof globalThis & {
        Calendly?: {
          initPopupWidget: (options: { url: string }) => void;
        };
      };

      const calendlyWindow = window as CalendlyWindow;

      const loadCalendly = (callback: () => void) => {
        if (calendlyWindow.Calendly?.initPopupWidget) {
          callback();
          return;
        }

        // Inject stylesheet
        if (!document.querySelector('link[href*="calendly.com"]')) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = 'https://assets.calendly.com/assets/external/widget.css';
          document.head.appendChild(link);
        }

        // Inject script if not already loading
        if (!document.querySelector('script[src*="calendly.com"]') && !calendlyLoading) {
          calendlyLoading = true;
          const script = document.createElement('script');
          script.src = 'https://assets.calendly.com/assets/external/widget.js';
          script.async = true;
          script.onload = () => {
            calendlyLoading = false;
            callback();
          };
          document.head.appendChild(script);
        } else {
          // If script is already inserted but not yet loaded, poll briefly
          const interval = setInterval(() => {
            if (calendlyWindow.Calendly?.initPopupWidget) {
              clearInterval(interval);
              callback();
            }
          }, 100);
        }
      };

      const initCalendlyButtons = () => {
        document.querySelectorAll('[data-calendly-url]').forEach((link) => {
          if (!(link instanceof HTMLAnchorElement) || link.dataset.bound === 'true') return;

          link.addEventListener('click', (event) => {
            event.preventDefault();
            const url = link.dataset.calendlyUrl;
            if (url) {
              if (localStorage.getItem('cookie-consent') === 'accepted') {
                try {
                  posthog.capture('calendly_booking_clicked', { url });
                } catch {
                  // Ignore analytics capture failures silently
                }
              }
              loadCalendly(() => {
                calendlyWindow.Calendly?.initPopupWidget({ url });
              });
            }
          });

          // Preload on mouse enter (hover) to eliminate dynamic loading lag
          link.addEventListener('mouseenter', () => {
            loadCalendly(() => {});
          }, { once: true });

          link.dataset.bound = 'true';
        });
      };

      if (document.readyState !== 'loading') {
        initCalendlyButtons();
      } else {
        document.addEventListener('DOMContentLoaded', initCalendlyButtons, { once: true });
      }

      document.addEventListener('astro:page-load', initCalendlyButtons);
    </script>
  </body>
</html>
